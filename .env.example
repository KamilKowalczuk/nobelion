PAYLOAD_API_URL=http://localhost:3001
PAYLOAD_API_KEY=PASTE_PAYLOAD_API_KEY_HERE
RESEND_API_KEY=re_PASTE_RESEND_API_KEY_HERE
EMAIL_FROM=kontakt@nobelion.pl
EMAIL_INTERNAL=kontakt@nobelion.pl
STRIPE_SECRET_KEY=sk_test_PASTE_STRIPE_SECRET_KEY_HERE
STRIPE_SUCCESS_URL=http://localhost:4321/dziekujemy?session_id={CHECKOUT_SESSION_ID}
STRIPE_CANCEL_URL=http://localhost:4321/blad-platnosci
# WEBHOOK_SECRET na froncie niepotrzebny — kanoniczny webhook to CMS (admin.nobelion.pl).
# Sekret admina dla endpointów ops: /api/invoices/download, /api/invoices/resend, /api/send-payment-link.
# FAIL-CLOSED: bez tego (min. 16 znaków) endpointy są zablokowane (503). Nagłówek: x-admin-secret.
ADMIN_API_SECRET=PASTE_RANDOM_ADMIN_SECRET_MIN_16_CHARS
# (Stary alias, nadal obsługiwany jako fallback:)
ADMIN_PAYMENT_LINK_SECRET=PASTE_RANDOM_ADMIN_SECRET_HERE
# Google Tag Manager — bez tego ID nie ładuje się ani GTM, ani baner cookie.
# Wartość wstawiana do HTML podczas builda (prefix PUBLIC_ = jawna, nie sekret).
PUBLIC_GTM_ID=GTM-XXXXXXX
