---
import Stripe from 'stripe';
import { backendEnv } from '../lib/backend-env';

// SSR — session_id przychodzi w query, więc strona NIE może być prerenderowana
// (statyczny build widzi puste parametry i na zawsze pokazuje błąd).
export const prerender = false;

const sessionId = Astro.url.searchParams.get('session_id') || '';
let verified = false;
let error = '';

if (!sessionId) {
    error = 'Brak identyfikatora sesji płatności.';
} else {
    const stripeKey = backendEnv('STRIPE_SECRET_KEY');
    if (!stripeKey) {
        error = 'Weryfikacja płatności jest chwilowo niedostępna.';
        console.error('[dziekujemy] Brak STRIPE_SECRET_KEY — nie można zweryfikować sesji.');
    } else {
        try {
            const stripe = new Stripe(stripeKey, { apiVersion: '2026-04-22.dahlia' });
            const session = await stripe.checkout.sessions.retrieve(sessionId);
            verified = session.payment_status === 'paid';
            if (!verified) error = 'Płatność nie została jeszcze zaksięgowana. Jeśli środki zeszły z konta, potwierdzenie dotrze mailem.';
        } catch (err: any) {
            console.error('[dziekujemy] Błąd weryfikacji sesji Stripe:', err?.message || err);
            error = 'Nie udało się potwierdzić płatności. Jeśli środki zeszły z konta, potwierdzenie dotrze mailem.';
        }
    }
}
---

<section class="min-h-[70vh] flex items-center justify-center px-6 py-24 bg-void text-silver">
    <div class="w-full max-w-2xl border border-white/10 bg-surface/30 p-10 text-center">
        {verified ? (
            <>
                <p class="font-mono text-brass text-xs tracking-[0.3em] uppercase mb-4">Płatność potwierdzona</p>
                <h1 class="font-heading text-3xl md:text-5xl tracking-[0.06em] uppercase mb-6">Dziękujemy</h1>
                <p class="text-steel text-base md:text-lg">Otrzymaliśmy Twoją płatność, zaczynamy pracę.</p>
            </>
        ) : (
            <>
                <p class="font-mono text-brass text-xs tracking-[0.3em] uppercase mb-4">Weryfikacja płatności</p>
                <h1 class="font-heading text-3xl md:text-5xl tracking-[0.06em] uppercase mb-6">Brak potwierdzenia</h1>
                <p class="text-steel text-base md:text-lg">{error}</p>
            </>
        )}
    </div>
</section>
