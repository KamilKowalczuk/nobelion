---
import Layout from '../layouts/Layout.astro';
import ScrollChoreography from '../components/core/ScrollChoreography.svelte';

import Hero from '../components/sections/Hero.astro';
import Marquee from '../components/ui/Marquee.astro';
import Services from '../components/sections/Services.astro';
import Benefits from '../components/sections/Benefits.astro';
import Cases from '../components/sections/Cases.astro';
import Process from '../components/sections/Process.astro';
import Security from '../components/sections/Security.astro';
import Brief from '../components/sections/Brief.astro';
import Faq from '../components/sections/Faq.astro';
import Footer from '../components/sections/Footer.astro';
---

<Layout>
    <ScrollChoreography client:idle />

    <div class="main-shell">
        <Hero />
        <Marquee />
        <Services />
        <Benefits />
        <Cases />
        <Process />
        <Security />
        <Brief />
        <Faq />
    </div>

    <Footer />
</Layout>

<style>
    .main-shell {
        position: relative;
        background-color: var(--color-paper);
    }
</style>

