---
import Layout from '../../layouts/Layout.astro';
import MagneticCursor from '../../components/core/MagneticCursor.svelte';

export const prerender = false; // Musi być SSR żeby pobierać z tokenu

const { token } = Astro.params;
// Ten sam mechanizm URL co w lib/payload.ts — działa na Netlify (process.env) i lokalnie (.env)
const apiUrl = (process.env.PAYLOAD_API_URL || import.meta.env.PAYLOAD_API_URL || 'http://localhost:3001').replace(/\/$/, '');

let quoteData = null;
let errorMsg = null;

try {
  const res = await fetch(`${apiUrl}/api/quotes/client/${token}`);
  if (res.ok) {
    quoteData = await res.json();
  } else {
    errorMsg = 'Nie znaleziono wyceny lub link wygasł.';
  }
} catch (e) {
  errorMsg = 'Błąd połączenia z serwerem.';
}

const blocks = quoteData?.content || [];
const fullPrice = quoteData?.totalPrice || 0;
const discountedPrice = Math.round(fullPrice * 0.9);
const briefCompany = quoteData?.brief?.company || 'Klienta';
const briefProblem = quoteData?.brief?.problemDescription || '';
---

<Layout title="Wycena Projektu - Nobelion" description="Twoja indywidualna wycena projektu.">
  <MagneticCursor client:load />
  <main class="min-h-screen bg-void pt-32 pb-24 px-4 md:px-12 selection:bg-brass/30 selection:text-white relative">
    <!-- Grid tła -->
    <div class="fixed inset-0 pointer-events-none opacity-[0.03] z-0" aria-hidden="true">
        <div class="absolute inset-0" style="background-image: linear-gradient(to right, #ffffff 1px, transparent 1px), linear-gradient(to bottom, #ffffff 1px, transparent 1px); background-size: 4rem 4rem;"></div>
    </div>

    <div class="max-w-5xl mx-auto relative z-10">
      {errorMsg ? (
        <div class="text-center py-20">
          <h1 class="text-3xl text-white font-heading mb-4">Ups!</h1>
          <p class="text-steel">{errorMsg}</p>
        </div>
      ) : (
        <div class="bg-surface/50 border border-white/10 shadow-2xl backdrop-blur-md overflow-hidden">
          
          {/* Header */}
          <div class="p-8 md:p-12 border-b border-white/5 bg-linear-to-br from-white/2 to-transparent">
            <div class="inline-block px-3 py-1 mb-6 border border-brass/30 text-brass text-xs uppercase tracking-widest font-mono">
                Propozycja Wdrożenia
            </div>
            <h1 class="text-3xl md:text-5xl font-heading font-light tracking-wide text-white mb-4">
              Wycena dla <span class="text-brass font-normal">{briefCompany}</span>
            </h1>
            <p class="text-steel text-lg max-w-2xl">Zgodnie z naszymi ustaleniami, przedstawiamy dedykowany plan inwestycji oraz szczegóły technologiczne dla Twojego rozwiązania.</p>
          </div>

          {/* Ciało oferty */}
          <div class="p-8 md:p-12 grid grid-cols-1 lg:grid-cols-3 gap-12">
            
            {/* Lewa kolumna: Opisy */}
            <div class="lg:col-span-2 space-y-12">
                
                {/* Renderowanie Bloków Payload CMS */}
                {blocks.length > 0 ? (
                    blocks.map((block: any) => {
                        if (block.blockType === 'richText') {
                            return (
                                <section class="prose prose-invert max-w-none text-steel leading-relaxed">
                                    <div set:html={block.text_html || block.text} />
                                </section>
                            );
                        }
                        if (block.blockType === 'timeline') {
                            return (
                                <section class="border-l border-white/10 pl-6 relative">
                                    <div class="absolute w-3 h-3 bg-brass rounded-full -left-[6.5px] top-1"></div>
                                    <h3 class="text-xl font-heading text-white mb-3">{block.phaseName}</h3>
                                    <p class="text-steel whitespace-pre-wrap">{block.description}</p>
                                </section>
                            );
                        }
                        return null;
                    })
                ) : (
                    <section>
                        <h2 class="text-2xl font-heading text-white mb-6 border-b border-white/10 pb-4">Wyzwanie</h2>
                        <p class="text-steel leading-relaxed">{briefProblem}</p>
                    </section>
                )}

                {/* Utrzymanie */}
                {quoteData.maintenancePrice ? (
                    <section class="bg-white/5 border border-white/10 p-6 md:p-8 relative overflow-hidden">
                        <div class="absolute top-0 right-0 w-32 h-32 bg-brass/10 rounded-full blur-3xl -mr-10 -mt-10"></div>
                        <h2 class="text-xl font-heading text-white mb-4">Opcjonalne wsparcie i utrzymanie</h2>
                        <div class="text-3xl font-heading text-brass mb-4">
                            {new Intl.NumberFormat('pl-PL').format(quoteData.maintenancePrice)} PLN <span class="text-sm text-steel font-sans font-normal uppercase tracking-wider">/ miesiąc</span>
                        </div>
                        <p class="text-steel mb-6 whitespace-pre-wrap">{quoteData.maintenanceDescription}</p>
                        
                        <label class="flex items-start gap-4 cursor-pointer p-4 bg-void/50 border border-white/10 hover:border-brass/50 transition-colors">
                            <div class="pt-1">
                                <input type="checkbox" id="maintenance-checkbox" class="w-5 h-5 accent-brass bg-void border-white/20" checked={quoteData.clientSelectedMaintenance} />
                            </div>
                            <div>
                                <span class="block text-white font-bold mb-1">Tak, chcę dodać pakiet utrzymania</span>
                                <span class="block text-sm text-steel">Zaznaczając to pole, deklarujesz chęć nawiązania współpracy abonamentowej. Płatność za utrzymanie zostanie uruchomiona po wdrożeniu projektu w oddzielnym procesie.</span>
                            </div>
                        </label>
                    </section>
                ) : null}

                {/* Przycisk prośby o zmiany */}
                <section class="pt-8 border-t border-white/10 flex flex-col items-start">
                    <p class="text-steel mb-4">Masz pytania lub chciałbyś zmodyfikować zakres tej wyceny?</p>
                    <button id="open-change-modal" class="inline-flex items-center text-brass hover:text-white transition-colors group">
                        <svg class="w-5 h-5 mr-2 transform group-hover:-rotate-12 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="square" stroke-linejoin="miter" stroke-width="1.5" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                        <span class="border-b border-brass/30 group-hover:border-white">Poproś o poprawki do wyceny</span>
                    </button>
                </section>

            </div>

            {/* Prawa kolumna: Płatności */}
            <div class="lg:col-span-1" id="payment-options" data-token={token} data-api={apiUrl}>
                <div class="sticky top-32 space-y-6">
                    <div class="mb-8">
                        <h2 class="text-sm font-mono text-brass uppercase tracking-widest mb-2">Całkowita wartość</h2>
                        <div class="text-4xl font-heading text-white line-through opacity-50 mb-1">
                            {new Intl.NumberFormat('pl-PL').format(fullPrice)} PLN
                        </div>
                        <div class="text-sm text-steel">Cena podstawowa (netto)</div>
                    </div>

                    <!-- Opcja 100% z rabatem -->
                    <button type="button" data-model="100" class="payment-btn w-full text-left relative p-6 border border-brass bg-brass/5 hover:bg-brass/10 transition-colors duration-300 group flex flex-col overflow-hidden">
                        <div class="absolute top-0 right-0 bg-brass text-void text-[10px] font-bold px-3 py-1 uppercase tracking-wider">
                            Rabat 10%
                        </div>
                        <h4 class="text-xl font-heading text-white mb-2">Płatność jednorazowa</h4>
                        <p class="text-steel text-sm mb-6 grow">Opłacasz z góry całą kwotę i otrzymujesz gwarantowany rabat.</p>
                        <div class="text-3xl font-heading text-brass mb-4">
                            {new Intl.NumberFormat('pl-PL').format(discountedPrice)} PLN
                        </div>
                        <div class="inline-flex items-center justify-center w-full bg-brass text-void font-bold py-3 px-6 hover:brightness-110 transition-all btn-text">
                            Opłać całość z rabatem
                        </div>
                    </button>

                    <!-- Opcja 50% -->
                    <button type="button" data-model="50" class="payment-btn w-full text-left p-6 border border-white/10 hover:border-white/30 transition-colors duration-300 group bg-surface h-full flex flex-col">
                        <h4 class="text-xl font-heading text-white mb-2">Płatność etapowa</h4>
                        <p class="text-steel text-sm mb-6 grow">Rozłożenie inwestycji w czasie (bez rabatu). Płacisz 50% na start.</p>
                        <div class="text-xl font-heading text-white mb-4">
                            {new Intl.NumberFormat('pl-PL').format(fullPrice / 2)} PLN <span class="text-xs text-steel font-sans font-normal uppercase tracking-wider block mt-1">Pierwsza Rata</span>
                        </div>
                        <div class="inline-flex items-center justify-center w-full border border-white/20 text-white font-bold py-3 px-6 group-hover:border-white transition-colors btn-text">
                            Opłać I ratę (50%)
                        </div>
                    </button>
                </div>
            </div>

          </div>
        </div>
      )}
    </div>

    <!-- Modal Formularza Zmian -->
    <div id="change-modal" class="fixed inset-0 z-50 flex items-center justify-center bg-void/80 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-300 p-4">
        <div class="bg-surface border border-white/10 p-8 max-w-lg w-full relative transform scale-95 transition-transform duration-300 shadow-2xl" id="change-modal-content">
            <button id="close-change-modal" class="absolute top-4 right-4 text-steel hover:text-white">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="square" stroke-linejoin="miter" stroke-width="1.5" d="M6 18L18 6M6 6l12 12"></path></svg>
            </button>
            
            <div id="change-form-state">
                <h3 class="text-2xl font-heading text-white mb-2">Zgłoś poprawki</h3>
                <p class="text-steel mb-6">Napisz nam, co chciałbyś zmienić w zakresie prac lub wycenie. Przygotujemy nową ofertę.</p>
                
                <textarea id="change-message" rows="5" class="w-full bg-void border border-white/10 text-white p-4 focus:outline-none focus:border-brass transition-colors resize-none mb-6" placeholder="Twoje uwagi..."></textarea>
                
                <button id="submit-change" class="w-full bg-white text-void font-bold py-3 px-6 hover:bg-brass hover:text-white transition-colors">
                    Wyślij prośbę o zmiany
                </button>
            </div>

            <div id="change-success-state" class="hidden text-center py-8">
                <div class="w-16 h-16 rounded-full border-2 border-brass flex items-center justify-center mx-auto mb-6 text-brass">
                    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="square" stroke-linejoin="miter" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                </div>
                <h3 class="text-2xl font-heading text-white mb-4">Prośba przyjęta!</h3>
                <p class="text-steel">Otrzymaliśmy Twoje uwagi. Wprowadzimy je i wkrótce prześlemy nową, zaktualizowaną wersję wyceny na Twój e-mail.</p>
                <button id="close-success-modal" class="mt-8 border border-white/20 text-white py-2 px-6 hover:border-white transition-colors">
                    Zamknij
                </button>
            </div>
        </div>
    </div>

  </main>
</Layout>

<script>
  // @ts-nocheck
  document.addEventListener('DOMContentLoaded', () => {
    const container = document.getElementById('payment-options');
    if (!container) return;

    const token = container.dataset.token;
    const apiUrl = container.dataset.api;
    const buttons = container.querySelectorAll('.payment-btn');

    // Obsługa Płatności Stripe
    buttons.forEach(btn => {
      btn.addEventListener('click', async (e) => {
        e.preventDefault();
        const btnText = btn.querySelector('.btn-text');
        const originalText = btnText.innerHTML;
        btnText.innerHTML = 'Przetwarzanie...';
        btn.disabled = true;

        const model = btn.dataset.model;

        try {
          const res = await fetch(`${apiUrl}/api/quotes/checkout/${token}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ paymentModel: model })
          });

          const data = await res.json();
          if (data.url) {
            window.location.href = data.url; 
          } else {
            alert('Wystąpił błąd: ' + (data.error || 'Nieznany błąd'));
            btnText.innerHTML = originalText;
            btn.disabled = false;
          }
        } catch (err) {
          alert('Błąd połączenia z serwerem.');
          btnText.innerHTML = originalText;
          btn.disabled = false;
        }
      });
    });

    const maintenanceCheckbox = document.getElementById('maintenance-checkbox');
    if (maintenanceCheckbox) {
      maintenanceCheckbox.addEventListener('change', async (e) => {
        const isChecked = e.target.checked;
        try {
          await fetch(`${apiUrl}/api/quotes/client/${token}/maintenance`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ wantsMaintenance: isChecked })
          });
        } catch (err) {
          console.error('Błąd zapisywania wyboru subskrypcji', err);
        }
      });
    }

    // Obsługa Modala Zmian
    const modal = document.getElementById('change-modal');
    const modalContent = document.getElementById('change-modal-content');
    const openBtn = document.getElementById('open-change-modal');
    const closeBtn = document.getElementById('close-change-modal');
    const submitBtn = document.getElementById('submit-change');
    const closeSuccessBtn = document.getElementById('close-success-modal');
    const messageInput = document.getElementById('change-message');
    
    const formState = document.getElementById('change-form-state');
    const successState = document.getElementById('change-success-state');

    const toggleModal = (show) => {
        if (show) {
            modal.classList.remove('opacity-0', 'pointer-events-none');
            modalContent.classList.remove('scale-95');
            modalContent.classList.add('scale-100');
        } else {
            modal.classList.add('opacity-0', 'pointer-events-none');
            modalContent.classList.remove('scale-100');
            modalContent.classList.add('scale-95');
        }
    };

    if(openBtn) openBtn.addEventListener('click', () => toggleModal(true));
    if(closeBtn) closeBtn.addEventListener('click', () => toggleModal(false));
    if(closeSuccessBtn) closeSuccessBtn.addEventListener('click', () => toggleModal(false));

    if(submitBtn) {
        submitBtn.addEventListener('click', async () => {
            const message = messageInput.value.trim();
            if(!message) {
                alert('Proszę wpisać treść uwag.');
                return;
            }

            const originalText = submitBtn.innerHTML;
            submitBtn.innerHTML = 'Wysyłanie...';
            submitBtn.disabled = true;

            try {
                const res = await fetch(`${apiUrl}/api/quotes/request-change/${token}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ message })
                });

                if (res.ok) {
                    formState.classList.add('hidden');
                    successState.classList.remove('hidden');
                } else {
                    const data = await res.json();
                    alert('Wystąpił błąd: ' + (data.error || 'Spróbuj ponownie później.'));
                    submitBtn.innerHTML = originalText;
                    submitBtn.disabled = false;
                }
            } catch (err) {
                alert('Błąd połączenia z serwerem.');
                submitBtn.innerHTML = originalText;
                submitBtn.disabled = false;
            }
        });
    }
  });
</script>
