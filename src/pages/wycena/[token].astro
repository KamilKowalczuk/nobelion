---
import Layout from '../../layouts/Layout.astro';
import { renderMarkdown } from '../../lib/markdown';

export const prerender = false;

const { token } = Astro.params;
const apiUrl = (process.env.PAYLOAD_API_URL || import.meta.env.PAYLOAD_API_URL || 'http://localhost:3001').replace(/\/$/, '');

let quoteData: any = null;
let errorMsg: string | null = null;

try {
  const res = await fetch(`${apiUrl}/api/quotes/client/${token}`);
  if (res.ok) {
    quoteData = await res.json();
  } else {
    errorMsg = 'Nie znaleziono wyceny lub link wygasł.';
  }
} catch {
  errorMsg = 'Błąd połączenia z serwerem.';
}

const fullPrice: number = quoteData?.totalPrice || 0;
const discountedPrice = Math.round(fullPrice * 0.9);
const briefCompany: string = quoteData?.brief?.company || 'Klienta';
const briefProblem: string = quoteData?.brief?.problemDescription || '';
// Po opłaceniu panel płatności zamienia się w potwierdzenie (endpoint i tak blokuje).
const paymentStatus: string = quoteData?.paymentStatus || 'unpaid';
const remainingPrice = fullPrice - Math.round(fullPrice / 2);

// Treść wyceny jest pisana w Markdown (pola textarea w panelu) → render + sanityzacja.
const introHtml = renderMarkdown(quoteData?.intro);
const timelineHtml = renderMarkdown(quoteData?.timelinePlan);
const scopeHtml = renderMarkdown(quoteData?.scopePlan);

// Dokumenty prawne do akceptacji (clickwrap). Publiczny endpoint, bez auth.
type LegalDoc = { docType: string; title: string; content: string };
let legalDocs: Record<string, { title: string; html: string }> = {};
if (quoteData && paymentStatus === 'unpaid') {
  try {
    const dres = await fetch(`${apiUrl}/api/documents/public`);
    if (dres.ok) {
      const dj = await dres.json();
      for (const d of (dj.documents || []) as LegalDoc[]) {
        legalDocs[d.docType] = { title: d.title, html: renderMarkdown(d.content) };
      }
    }
  } catch { /* dokumenty opcjonalne — brak nie blokuje renderu strony */ }
}
const docOrder = ['umowa-wspolpracy', 'regulamin', 'polityka-prywatnosci'] as const;
const consentDocs = docOrder
  .filter((t) => legalDocs[t])
  .map((t) => ({ type: t, title: legalDocs[t].title, html: legalDocs[t].html }));

const fmt = (n: number) => new Intl.NumberFormat('pl-PL').format(n);
---

<Layout>
  {errorMsg ? (
    <section class="onyx q-error">
      <div class="wrap q-error__inner">
        <span class="eyebrow">Błąd</span>
        <h1 class="h2 q-error__title">Nie znaleziono wyceny</h1>
        <p class="lead">{errorMsg}</p>
        <a href="/" class="nb-btn nb-btn--ghost-light nb-btn--lg q-error__cta">
          <span class="nb-btn__label">Wróć na stronę główną</span>
        </a>
      </div>
    </section>
  ) : (
    <>
      {/* ───────── ONYX HERO BAND ───────── */}
      <section class="onyx q-hero">
        <div class="q-hero__bg" aria-hidden="true">
          <div class="q-hero__glow"></div>
          <div class="q-hero__grid"></div>
        </div>
        <div class="wrap q-hero__inner">
          <div class="q-hero__eyebrow">
            <span class="q-hero__dot"></span>
            <span class="eyebrow">Propozycja wdrożenia</span>
          </div>
          <h1 class="q-hero__title">
            Wycena dla <span class="q-hero__accent">{briefCompany}</span>
          </h1>
          <p class="q-hero__sub">
            Zgodnie z naszymi ustaleniami, przedstawiamy dedykowany plan inwestycji oraz
            szczegóły technologiczne dla Twojego rozwiązania.
          </p>
        </div>
      </section>

      {/* ───────── LIGHT BODY (overlapping panel) ───────── */}
      <section class="section q-body nb-panel bg-paper">
        <div class="wrap">
          <div class="q-grid">

            {/* LEFT — treść */}
            <div class="q-content">

              {introHtml ? (
                <div class="rt" set:html={introHtml} />
              ) : briefProblem ? (
                <section class="q-section">
                  <h2 class="q-h"><span class="q-h__mark" aria-hidden="true"></span>Wyzwanie</h2>
                  <p class="q-problem">{briefProblem}</p>
                </section>
              ) : null}

              {timelineHtml && (
                <section class="q-section">
                  <h2 class="q-h"><span class="q-h__mark" aria-hidden="true"></span>Plan realizacji</h2>
                  <div class="rt" set:html={timelineHtml} />
                </section>
              )}

              {scopeHtml && (
                <section class="q-section">
                  <h2 class="q-h"><span class="q-h__mark" aria-hidden="true"></span>Zakres prac</h2>
                  <div class="rt" set:html={scopeHtml} />
                </section>
              )}

              <div class="q-change">
                <p>Masz pytania lub chciałbyś zmodyfikować zakres tej wyceny?</p>
                <button id="open-change-modal" class="q-change__btn" type="button">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="square" stroke-linejoin="miter">
                    <path d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                  </svg>
                  <span>Poproś o poprawki do wyceny</span>
                </button>
              </div>
            </div>

            {/* RIGHT — płatność */}
            <aside class="q-pay" id="payment-options" data-token={token} data-api={apiUrl}>
              <div class="q-pay__sticky">
                <div class="q-pay__head">
                  <span class="eyebrow">Całkowita wartość</span>
                  <div class="q-pay__full">{fmt(fullPrice)} PLN</div>
                  <span class="caption">Cena podstawowa (netto)</span>
                </div>

                {paymentStatus === 'paid_full' ? (
                  <div class="q-paid">
                    <span class="q-paid__check" aria-hidden="true">
                      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="square" stroke-linejoin="miter">
                        <path d="M5 12.5 L10 17.5 L19 6.5" />
                      </svg>
                    </span>
                    <h3 class="h4 q-paid__title">Opłacone w całości</h3>
                    <p class="q-paid__desc">Dziękujemy — realizacja jest w toku. Potwierdzenie płatności i faktura trafiły na Twój e-mail.</p>
                  </div>
                ) : paymentStatus === 'paid_half' ? (
                  <div class="q-paid">
                    <span class="q-paid__check" aria-hidden="true">
                      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="square" stroke-linejoin="miter">
                        <path d="M5 12.5 L10 17.5 L19 6.5" />
                      </svg>
                    </span>
                    <h3 class="h4 q-paid__title">I rata opłacona</h3>
                    <p class="q-paid__desc">Pracujemy nad Twoim projektem. Pozostałą część ({fmt(remainingPrice)} PLN) opłacisz linkiem, który wyślemy mailem na koniec prac.</p>
                  </div>
                ) : (
                  <>
                    {/* Opcjonalny add-on: opieka po wdrożeniu — przy decyzji o płatności */}
                    {quoteData.maintenancePrice ? (
                      <label class="q-addon">
                        <input type="checkbox" id="maintenance-checkbox" checked={quoteData.clientSelectedMaintenance} />
                        <span class="q-addon__box" aria-hidden="true">
                          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="square"><path d="M5 12.5 L10 17.5 L19 6.5"/></svg>
                        </span>
                        <span class="q-addon__body">
                          <span class="q-addon__top">
                            <span class="q-addon__name">Opieka po wdrożeniu</span>
                            <span class="q-addon__price">+{fmt(quoteData.maintenancePrice)} zł/mies.</span>
                          </span>
                          <span class="q-addon__desc">{quoteData.maintenanceDescription || 'Monitoring, utrzymanie i drobne poprawki po starcie.'} Płatność uruchamiamy osobno po wdrożeniu.</span>
                        </span>
                      </label>
                    ) : null}

                    {/* Dokumenty i zgody (clickwrap) — bramka na płatność */}
                    <div class="q-consent" id="q-consent">
                      <span class="caption q-consent__h">Dokumenty i zgody</span>
                      {consentDocs.length > 0 ? (
                        <div class="q-consent__docs">
                          {consentDocs.map((d) => (
                            <button type="button" class="q-consent__doc" data-doc={d.type}>
                              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"><path d="M7 3h7l5 5v13H7zM14 3v5h5"/></svg>
                              <span>{d.title}</span>
                            </button>
                          ))}
                        </div>
                      ) : (
                        <p class="q-consent__empty">Dokumenty pojawią się tutaj po dodaniu w panelu.</p>
                      )}
                      <label class="q-consent__check">
                        <input type="checkbox" id="consent-docs" />
                        <span class="q-consent__cbox" aria-hidden="true"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="square"><path d="M5 12.5 L10 17.5 L19 6.5"/></svg></span>
                        <span>Zapoznałem się i akceptuję umowę współpracy, regulamin oraz politykę prywatności.</span>
                      </label>
                      <label class="q-consent__check">
                        <input type="checkbox" id="consent-withdrawal" />
                        <span class="q-consent__cbox" aria-hidden="true"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="square"><path d="M5 12.5 L10 17.5 L19 6.5"/></svg></span>
                        <span>Zamawiam wykonanie spersonalizowanego rozwiązania według mojej specyfikacji i żądam rozpoczęcia prac. Przyjmuję do wiadomości, że po rozpoczęciu świadczenia nie przysługuje mi prawo odstąpienia w terminie 14 dni.</span>
                      </label>
                    </div>

                    {/* Jednorazowa — rabat 10% */}
                    <button type="button" data-model="100" class="payment-btn q-opt q-opt--primary" disabled>
                      <span class="q-opt__ribbon">Rabat 10%</span>
                      <h3 class="h4 q-opt__title">Płatność jednorazowa</h3>
                      <p class="q-opt__desc">Opłacasz z góry całą kwotę i otrzymujesz gwarantowany rabat 10%.</p>
                      <div class="q-opt__price q-opt__price--accent">{fmt(discountedPrice)} PLN</div>
                      <span class="btn-text q-opt__cta q-opt__cta--solid">Opłać całość z rabatem</span>
                    </button>

                    {/* Etapowa — 50% */}
                    <button type="button" data-model="50" class="payment-btn q-opt" disabled>
                      <h3 class="h4 q-opt__title">Płatność etapowa</h3>
                      <p class="q-opt__desc">Płacisz 50% na start, resztę po zakończeniu projektu (bez rabatu).</p>
                      <div class="q-opt__price">{fmt(fullPrice / 2)} PLN</div>
                      <span class="caption q-opt__sub">Pierwsza rata</span>
                      <span class="btn-text q-opt__cta q-opt__cta--ghost">Opłać I ratę (50%)</span>
                    </button>

                    <p class="q-consent__hint" id="consent-hint">Zaznacz obie zgody powyżej, aby odblokować płatność.</p>
                  </>
                )}
              </div>
            </aside>

            {/* Modale dokumentów prawnych */}
            {consentDocs.map((d) => (
              <div class="q-docmodal" id={`docmodal-${d.type}`} data-docmodal={d.type}>
                <div class="q-docmodal__box">
                  <button type="button" class="q-docmodal__close" data-close-doc aria-label="Zamknij">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"><path d="M6 18L18 6M6 6l12 12"/></svg>
                  </button>
                  <h3 class="h3 q-docmodal__title">{d.title}</h3>
                  <div class="q-docmodal__body rt" set:html={d.html} />
                </div>
              </div>
            ))}

          </div>
        </div>
      </section>

      {/* ───────── MODAL ───────── */}
      <div id="change-modal" class="q-modal">
        <div id="change-modal-content" class="q-modal__box">
          <button id="close-change-modal" class="q-modal__close" aria-label="Zamknij" type="button">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="square" stroke-linejoin="miter">
              <path d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
          <div id="change-form-state">
            <span class="eyebrow">Poprawki</span>
            <h3 class="h3 q-modal__title">Zgłoś zmiany</h3>
            <p class="q-modal__lead">Napisz co chciałbyś zmienić w zakresie lub wycenie. Przygotujemy nową ofertę.</p>
            <textarea id="change-message" rows="5" maxlength="2000" class="q-modal__field" placeholder="Twoje uwagi..."></textarea>
            <button id="submit-change" class="nb-btn nb-btn--primary nb-btn--lg q-modal__submit" type="button">
              <span class="nb-btn__label">Wyślij prośbę o zmiany</span>
            </button>
          </div>
          <div id="change-success-state" class="q-modal__success">
            <div class="q-modal__check">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square" stroke-linejoin="miter">
                <path d="M5 13l4 4L19 7"/>
              </svg>
            </div>
            <h3 class="h3 q-modal__title">Prośba przyjęta</h3>
            <p class="q-modal__lead">Otrzymaliśmy Twoje uwagi. Wrócimy z poprawioną wersją wyceny na Twój e-mail.</p>
            <button id="close-success-modal" class="nb-btn nb-btn--ghost-light nb-btn--md q-modal__close-btn" type="button" style="border-color:var(--color-hair-ink);color:var(--color-ink-2);">
              <span class="nb-btn__label">Zamknij</span>
            </button>
          </div>
        </div>
      </div>
    </>
  )}
</Layout>

<style>
/* ============================================================
   QUOTE — onyx hero + light editorial body (Nobelion design system)
   ============================================================ */

/* ── ONYX HERO BAND ── */
.q-hero {
  position: relative;
  overflow: hidden;
  background-color: var(--color-onyx);
  color: var(--color-silver);
  padding-top: clamp(128px, 17vh, 196px);
  padding-bottom: clamp(96px, 12vw, 168px);
}
.q-hero__bg { position: absolute; inset: 0; z-index: 0; }
.q-hero__glow {
  position: absolute; top: -30%; left: 50%; transform: translateX(-50%);
  width: min(900px, 110vw); height: 700px;
  background: radial-gradient(ellipse at center, rgba(197,160,89,0.18), rgba(197,160,89,0.04) 40%, transparent 66%);
  filter: blur(8px);
}
.q-hero__grid {
  position: absolute; inset: 0; opacity: 0.5;
  background-image:
    linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);
  background-size: 64px 64px;
  mask-image: radial-gradient(ellipse 80% 70% at 50% 40%, #000 30%, transparent 75%);
  -webkit-mask-image: radial-gradient(ellipse 80% 70% at 50% 40%, #000 30%, transparent 75%);
}
.q-hero__inner { position: relative; z-index: 2; }
.q-hero__eyebrow { display: inline-flex; align-items: center; gap: 10px; margin-bottom: 26px; }
.q-hero__dot {
  width: 7px; height: 7px; border-radius: 50%;
  background: var(--color-brass-bright);
  box-shadow: 0 0 12px 1px var(--color-brass-glow);
  animation: q-pulse 2.6s cubic-bezier(0.65,0,0.35,1) infinite;
}
@keyframes q-pulse { 0%,100% { opacity: 1; } 50% { opacity: 0.35; } }
.q-hero__title {
  font-family: var(--font-heading); font-weight: 700; text-transform: uppercase;
  line-height: 1.04; letter-spacing: 0.04em; color: var(--color-silver);
  margin: 0; font-size: clamp(28px, 5vw, 68px); max-width: 16ch;
  overflow-wrap: break-word; word-break: break-word;
}
.q-hero__accent { color: var(--color-brass-bright); }
.q-hero__sub {
  max-width: 60ch; margin: 28px 0 0;
  font-size: clamp(16px, 1.4vw, 19px); line-height: 1.6;
  color: var(--color-silver-soft);
}

/* ── LIGHT BODY ── */
.q-body { background: var(--color-paper); padding-top: clamp(56px, 7vw, 96px); }
.q-grid {
  display: grid; grid-template-columns: 1.6fr 0.9fr; gap: clamp(40px, 5vw, 80px);
  align-items: start;
}

/* left content */
.q-content { min-width: 0; }
.q-section { margin-bottom: clamp(40px, 5vw, 64px); }
.q-h {
  display: flex; align-items: center; gap: 14px;
  font-family: var(--font-heading); font-weight: 600; font-size: var(--fs-h4);
  letter-spacing: var(--tracking-cinematic); text-transform: uppercase;
  color: var(--color-ink); margin: 0 0 22px; padding-bottom: 18px;
  border-bottom: 1px solid var(--color-hair-ink);
}
.q-h__mark {
  width: 11px; height: 11px; flex-shrink: 0;
  border: 1px solid var(--color-brass); transform: rotate(45deg);
  position: relative;
}
.q-h__mark::after {
  content: ""; position: absolute; inset: 3px; background: var(--color-brass);
}
.q-problem { color: var(--color-ink-2); line-height: var(--lh-body); white-space: pre-wrap; }

/* ── rich text (light) ── */
.rt { color: var(--color-ink-2); overflow-wrap: break-word; word-break: break-word; }
.rt :global(p) { color: var(--color-ink-2); line-height: 1.72; margin: 0 0 1.1rem; overflow-wrap: break-word; }
.rt :global(h1), .rt :global(h2), .rt :global(h3), .rt :global(h4), .rt :global(h5), .rt :global(h6) {
  font-family: var(--font-heading); font-weight: 600;
  letter-spacing: var(--tracking-cinematic); text-transform: uppercase;
  color: var(--color-ink); margin: 2rem 0 0.85rem; line-height: 1.25;
}
.rt :global(h1) { font-size: var(--fs-h3); }
.rt :global(h2) { font-size: var(--fs-h4); }
.rt :global(h3), .rt :global(h4), .rt :global(h5), .rt :global(h6) { font-size: 1rem; }
.rt :global(h1):first-child, .rt :global(h2):first-child, .rt :global(h3):first-child { margin-top: 0; }
.rt :global(hr) { border: none; border-top: 1px solid var(--color-hair-ink); margin: 1.8rem 0; }
.rt :global(code) {
  font-family: var(--font-mono); font-size: 0.875em;
  background: var(--color-paper-3); padding: 0.1em 0.4em; border-radius: var(--r-inset);
  color: var(--color-ink);
}
.rt :global(ul), .rt :global(ol) { margin: 0 0 1.1rem; padding: 0; list-style: none; }
.rt :global(li) {
  position: relative; padding-left: 1.6em;
  color: var(--color-ink-2); line-height: 1.7; margin-bottom: 0.55rem;
  overflow-wrap: break-word;
}
.rt :global(ul > li)::before {
  content: "—"; position: absolute; left: 0; top: 0; color: var(--color-brass);
}
.rt :global(ol) { counter-reset: c; }
.rt :global(ol > li) { counter-increment: c; }
.rt :global(ol > li)::before {
  content: counter(c) "."; position: absolute; left: 0; top: 0;
  color: var(--color-brass); font-family: var(--font-mono);
}
/* zagnieżdżone listy i akapity w punktach */
.rt :global(li > ul), .rt :global(li > ol) { margin: 0.45rem 0 0.2rem; }
.rt :global(li > p) { margin: 0 0 0.5rem; }
.rt :global(a) { color: var(--color-brass); text-decoration: underline; text-underline-offset: 3px; transition: color var(--dur-fast) var(--ease-out); }
.rt :global(a):hover { color: var(--color-brass-dark); }
.rt :global(strong) { color: var(--color-ink); font-weight: 600; }
.rt :global(blockquote) {
  border-left: 2px solid var(--color-brass); padding-left: 1.1rem;
  margin: 1.2rem 0; color: var(--color-ink-3); font-style: italic;
}
.rt :global(s), .rt :global(del) { color: var(--color-ink-4); }
.rt :global(img) { max-width: 100%; height: auto; border-radius: var(--r-inset); margin: 1rem 0; }
.rt :global(pre) {
  background: var(--color-paper-3); border: 1px solid var(--color-hair-ink);
  border-radius: var(--r-card); padding: 1rem 1.2rem; overflow-x: auto; margin: 1.2rem 0;
}
.rt :global(pre code) { background: none; padding: 0; font-size: 0.875rem; line-height: 1.6; }

/* Tabele (GFM) — owinięte w przewijalny kontener (.nb-table-wrap) */
.rt :global(.nb-table-wrap) {
  margin: 1.4rem 0; overflow-x: auto; -webkit-overflow-scrolling: touch;
  border-bottom: 1px solid var(--color-hair-ink-2);
}
.rt :global(.nb-table-wrap)::-webkit-scrollbar { height: 6px; }
.rt :global(.nb-table-wrap)::-webkit-scrollbar-track { background: transparent; }
.rt :global(.nb-table-wrap)::-webkit-scrollbar-thumb {
  background: color-mix(in srgb, var(--color-brass), transparent 55%); border-radius: 3px;
}
.rt :global(table) {
  width: 100%; min-width: 30rem; border-collapse: collapse; margin: 0;
  font-size: 0.95rem;
}
.rt :global(thead) { border-bottom: 2px solid var(--color-brass); }
.rt :global(th) {
  text-align: left; padding: 0.7rem 0.9rem;
  font-family: var(--font-mono); font-size: 0.75rem; letter-spacing: 0.08em;
  text-transform: uppercase; color: var(--color-ink); font-weight: 600;
}
.rt :global(td) {
  padding: 0.7rem 0.9rem; border-top: 1px solid var(--color-hair-ink);
  color: var(--color-ink-2); vertical-align: top; overflow-wrap: break-word;
}
.rt :global(tbody tr):hover { background: var(--color-paper-3); }

/* ── add-on opieki (w kolumnie płatności) ── */
.q-addon {
  display: flex; gap: 12px; align-items: flex-start; cursor: pointer;
  border: 1px solid var(--color-paper-edge); border-radius: var(--r-card);
  padding: 16px 18px; background: var(--color-paper);
  transition: border-color var(--dur-base) var(--ease-out), background var(--dur-base) var(--ease-out);
}
.q-addon:hover { border-color: var(--color-brass); }
.q-addon input { position: absolute; opacity: 0; width: 0; height: 0; }
.q-addon__box {
  flex-shrink: 0; width: 22px; height: 22px; margin-top: 1px; border-radius: 6px;
  border: 1px solid var(--color-paper-edge); display: flex; align-items: center; justify-content: center;
  color: transparent; transition: all var(--dur-fast);
}
.q-addon input:checked + .q-addon__box { background: var(--color-brass); border-color: var(--color-brass); color: var(--color-void); }
.q-addon input:checked ~ .q-addon__body { color: var(--color-ink); }
.q-addon__body { display: flex; flex-direction: column; gap: 5px; min-width: 0; }
.q-addon__top { display: flex; align-items: baseline; justify-content: space-between; gap: 10px; }
.q-addon__name { font-family: var(--font-heading); font-weight: 600; font-size: 14px; letter-spacing: 0.04em; text-transform: uppercase; color: var(--color-ink); }
.q-addon__price { font-family: var(--font-mono); font-size: 13px; color: var(--color-brass-dark); white-space: nowrap; }
.q-addon__desc { font-size: 12.5px; line-height: 1.55; color: var(--color-ink-3); }

/* ── dokumenty i zgody (clickwrap) ── */
.q-consent {
  border: 1px solid var(--color-paper-edge); border-radius: var(--r-card);
  padding: 16px 18px; display: flex; flex-direction: column; gap: 12px;
  background: var(--color-paper-2);
}
.q-consent__h { display: block; color: var(--color-ink-3); }
.q-consent__docs { display: flex; flex-direction: column; gap: 6px; }
.q-consent__doc {
  display: inline-flex; align-items: center; gap: 9px; text-align: left;
  background: none; border: none; cursor: pointer; padding: 4px 0;
  font-size: 13px; color: var(--color-brass-dark); text-decoration: underline; text-underline-offset: 3px;
  transition: color var(--dur-fast);
}
.q-consent__doc:hover { color: var(--color-ink); }
.q-consent__doc svg { flex-shrink: 0; color: var(--color-ink-4); }
.q-consent__empty { font-size: 12px; color: var(--color-ink-4); margin: 0; }
.q-consent__check { display: flex; gap: 11px; align-items: flex-start; cursor: pointer; }
.q-consent__check input { position: absolute; opacity: 0; width: 0; height: 0; }
.q-consent__cbox {
  flex-shrink: 0; width: 20px; height: 20px; margin-top: 1px; border-radius: 5px;
  border: 1px solid var(--color-paper-edge); display: flex; align-items: center; justify-content: center;
