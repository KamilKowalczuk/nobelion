---
import Layout from '../../layouts/Layout.astro';
import { renderMarkdown } from '../../lib/markdown';
import QuotePaymentWidget from '../../components/ui/QuotePaymentWidget.svelte';
import QuoteChangeModal from '../../components/ui/QuoteChangeModal.svelte';
import { BUSINESS_CONFIG, PAYMENT_MODELS, PAYMENT_STATUSES, getApiUrl, API_ENDPOINTS } from '../../lib/constants';

export const prerender = false;

const token = Astro.params.token || '';
const apiUrl = getApiUrl();

let quoteData: any = null;
let errorMsg: string | null = null;

try {
  const res = await fetch(`${apiUrl}${API_ENDPOINTS.quoteByToken(token)}`);
  if (res.ok) {
    quoteData = await res.json();
  } else {
    errorMsg = 'Nie znaleziono wyceny lub link wygasł.';
  }
} catch {
  errorMsg = 'Błąd połączenia z serwerem.';
}

const fullPrice: number = quoteData?.totalPrice || 0;
const briefCompany: string = quoteData?.brief?.company || 'Klienta';
const briefProblem: string = quoteData?.brief?.problemDescription || '';
const paymentStatus: string = quoteData?.paymentStatus || PAYMENT_STATUSES.UNPAID;

const introHtml = renderMarkdown(quoteData?.intro);
const timelineHtml = renderMarkdown(quoteData?.timelinePlan);
const scopeHtml = renderMarkdown(quoteData?.scopePlan);

type LegalDoc = { docType: string; title: string; content: string; version?: string };
let legalDocs: Record<string, { title: string; html: string; version?: string }> = {};
if (quoteData && paymentStatus === PAYMENT_STATUSES.UNPAID) {
  try {
    const dres = await fetch(`${apiUrl}${API_ENDPOINTS.publicDocuments()}`);
    if (dres.ok) {
      const dj = await dres.json();
      for (const d of (dj.documents || []) as LegalDoc[]) {
        legalDocs[d.docType] = { title: d.title, html: renderMarkdown(d.content), version: d.version };
      }
    }
  } catch { /* ignored */ }
}
---

<Layout title={`Wycena: ${briefCompany} | Nobelion`} noindex={true}>
  {errorMsg ? (
    <section class="onyx min-h-[70vh] flex items-center pt-[120px] pb-[80px] bg-onyx text-silver">
      <div class="wrap text-center">
        <span class="eyebrow">Błąd</span>
        <h1 class="h2 m-[16px_0] text-silver">Nie znaleziono wyceny</h1>
        <p class="lead">{errorMsg}</p>
        <a href="/" class="nb-btn nb-btn--ghost-light nb-btn--lg mt-[28px]">
          <span class="nb-btn__label">Wróć na stronę główną</span>
        </a>
      </div>
    </section>
  ) : (
    <>
      <section class="onyx relative overflow-hidden bg-onyx text-silver pt-[clamp(128px,17vh,196px)] pb-[clamp(96px,12vw,168px)] max-[640px]:pt-[clamp(100px,15vh,140px)] max-[640px]:pb-[clamp(52px,11vw,88px)]">
        <div class="absolute inset-0 z-0" aria-hidden="true">
          <div class="absolute top-[-30%] left-1/2 -translate-x-1/2 w-[min(900px,110vw)] h-[700px] blur-[8px]" style="background: radial-gradient(ellipse at center, rgba(197,160,89,0.18), rgba(197,160,89,0.04) 40%, transparent 66%);"></div>
          <div class="absolute inset-0 opacity-50 bg-[size:64px_64px]" style="background-image: linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px); mask-image: radial-gradient(ellipse 80% 70% at 50% 40%, #000 30%, transparent 75%); -webkit-mask-image: radial-gradient(ellipse 80% 70% at 50% 40%, #000 30%, transparent 75%);"></div>
        </div>
        <div class="wrap relative z-2">
          <div class="inline-flex items-center gap-[10px] mb-[26px]">
            <span class="w-[7px] h-[7px] rounded-full bg-brass-bright shadow-[0_0_12px_1px_var(--color-brass-glow)] motion-safe:animate-[q-pulse_2.6s_cubic-bezier(0.65,0,0.35,1)_infinite]"></span>
            <span class="eyebrow">Propozycja wdrożenia</span>
          </div>
          <h1 class="font-heading font-bold uppercase leading-[1.04] tracking-[0.04em] text-silver m-0 text-[clamp(28px,5vw,68px)] max-w-[16ch] break-words">
            Wycena dla <span class="text-brass-bright">{briefCompany}</span>
          </h1>
          <p class="max-w-[60ch] m-[28px_0_0] text-[clamp(16px,1.4vw,19px)] leading-[1.6] text-silver-soft">
            Zgodnie z naszymi ustaleniami, przedstawiamy dedykowany plan inwestycji oraz
            szczegóły technologiczne dla Twojego rozwiązania.
          </p>
        </div>
      </section>

      <section class="section nb-panel bg-paper pt-[clamp(56px,7vw,96px)]">
        <div class="wrap">
          <div class="grid grid-cols-[1.6fr_0.9fr] gap-[clamp(40px,5vw,80px)] items-start max-[980px]:grid-cols-1 max-[980px]:gap-[48px]">

            <div class="min-w-0">
              {introHtml ? (
                <div class="rt" set:html={introHtml} />
              ) : briefProblem ? (
                <section class="mb-[clamp(40px,5vw,64px)]">
                  <h2 class="flex items-center gap-[14px] max-[640px]:gap-[10px] font-heading font-semibold text-[var(--fs-h4)] max-[640px]:text-[1rem] tracking-[var(--tracking-cinematic)] uppercase text-ink m-[0_0_22px] pb-[18px] border-b border-hair-ink">
                    <span class="w-[11px] h-[11px] shrink-0 border border-brass rotate-45 relative after:content-[''] after:absolute after:inset-[3px] after:bg-brass" aria-hidden="true"></span>
                    Wyzwanie
                  </h2>
                  <p class="text-ink-2 leading-[var(--lh-body)] whitespace-pre-wrap">{briefProblem}</p>
                </section>
              ) : null}

              {timelineHtml && (
                <section class="mb-[clamp(40px,5vw,64px)]">
                  <h2 class="flex items-center gap-[14px] max-[640px]:gap-[10px] font-heading font-semibold text-[var(--fs-h4)] max-[640px]:text-[1rem] tracking-[var(--tracking-cinematic)] uppercase text-ink m-[0_0_22px] pb-[18px] border-b border-hair-ink">
                    <span class="w-[11px] h-[11px] shrink-0 border border-brass rotate-45 relative after:content-[''] after:absolute after:inset-[3px] after:bg-brass" aria-hidden="true"></span>
                    Plan realizacji
                  </h2>
                  <div class="rt" set:html={timelineHtml} />
                </section>
              )}

              {scopeHtml && (
                <section class="mb-[clamp(40px,5vw,64px)]">
                  <h2 class="flex items-center gap-[14px] max-[640px]:gap-[10px] font-heading font-semibold text-[var(--fs-h4)] max-[640px]:text-[1rem] tracking-[var(--tracking-cinematic)] uppercase text-ink m-[0_0_22px] pb-[18px] border-b border-hair-ink">
                    <span class="w-[11px] h-[11px] shrink-0 border border-brass rotate-45 relative after:content-[''] after:absolute after:inset-[3px] after:bg-brass" aria-hidden="true"></span>
                    Zakres prac
                  </h2>
                  <div class="rt" set:html={scopeHtml} />
                </section>
              )}

              <QuoteChangeModal client:load {apiUrl} {token} />
            </div>

            <QuotePaymentWidget client:load {apiUrl} {token} {fullPrice} {quoteData} {legalDocs} />

          </div>
        </div>
      </section>
    </>
  )}
</Layout>

<style>
@keyframes q-pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.35; }
}
</style>
