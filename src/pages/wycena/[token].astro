.q-docmodal__box {
  position: relative; background: var(--color-paper); border-radius: var(--r-card);
  max-width: 760px; width: 100%; max-height: 86vh; overflow-y: auto;
  padding: clamp(28px, 4vw, 48px); box-shadow: var(--shadow-lift);
}
.q-docmodal__close {
  position: absolute; top: 16px; right: 16px; background: none; border: none; cursor: pointer;
  color: var(--color-ink-3); padding: 6px; transition: color var(--dur-fast);
}
.q-docmodal__close:hover { color: var(--color-ink); }
.q-docmodal__title { margin: 0 0 20px; color: var(--color-ink); }
.q-docmodal__body { color: var(--color-ink-2); line-height: 1.7; font-size: 15px; }

/* ── change request ── */
.q-change { padding-top: clamp(28px, 3vw, 40px); border-top: 1px solid var(--color-hair-ink); }
.q-change p { font-size: 14px; color: var(--color-ink-3); margin: 0 0 16px; }
.q-change__btn {
  display: inline-flex; align-items: center; gap: 10px;
  font-family: var(--font-mono); font-size: 13px; letter-spacing: 0.06em;
  color: var(--color-brass-dark); background: none; border: none; cursor: pointer; padding: 0;
  transition: color var(--dur-base) var(--ease-out);
}
.q-change__btn svg { transition: transform var(--dur-base) var(--ease-out); }
.q-change__btn:hover { color: var(--color-ink); }
.q-change__btn:hover svg { transform: rotate(-12deg); }
.q-change__btn span { border-bottom: 1px solid var(--color-brass-glow); padding-bottom: 2px; }

/* ── payment (right) ── */
.q-pay { min-width: 0; }
.q-pay__sticky { position: sticky; top: 96px; display: flex; flex-direction: column; gap: 18px; }
.q-pay__head { margin-bottom: 6px; }
.q-pay__full {
  font-family: var(--font-heading); font-weight: 700;
  font-size: clamp(32px, 3.4vw, 42px); color: var(--color-ink-4);
  text-decoration: line-through; line-height: 1; margin: 12px 0 8px;
}

.q-opt {
  position: relative; display: flex; flex-direction: column; text-align: left;
  width: 100%; cursor: pointer; padding: clamp(22px, 2.4vw, 30px);
  background: var(--color-paper-2);
  border: 1px solid var(--color-hair-ink);
  border-radius: var(--r-card);
  transition: border-color var(--dur-base) var(--ease-out), box-shadow var(--dur-base) var(--ease-out), transform var(--dur-base) var(--ease-out);
}
.q-opt:hover { border-color: var(--color-ink-4); box-shadow: var(--shadow-lift); transform: translateY(-2px); }
.q-opt:disabled { opacity: 0.6; cursor: wait; transform: none; }

.q-opt--primary {
  border-color: var(--color-brass);
  background: linear-gradient(160deg, color-mix(in srgb, var(--color-brass) 7%, var(--color-paper-2)), var(--color-paper-2));
}
.q-opt--primary:hover { border-color: var(--color-brass-dark); box-shadow: var(--glow-brass), var(--shadow-lift); }

.q-opt__ribbon {
  position: absolute; top: 0; right: 0;
  background: var(--color-brass); color: var(--color-void);
  font-family: var(--font-mono); font-size: 10px; font-weight: 600;
  letter-spacing: 0.14em; text-transform: uppercase; padding: 6px 12px;
  border-bottom-left-radius: var(--r-inset);
}
.q-opt__title { margin: 0 0 10px; color: var(--color-ink); }
.q-opt__desc { font-size: 14px; line-height: 1.6; color: var(--color-ink-3); margin: 0 0 20px; flex-grow: 1; }
.q-opt__price {
  font-family: var(--font-heading); font-weight: 700;
  font-size: clamp(24px, 2.6vw, 30px); color: var(--color-ink); line-height: 1; margin-bottom: 4px;
}
.q-opt__price--accent { color: var(--color-brass-dark); }
.q-opt__sub { display: block; margin-bottom: 18px; }

/* panel po opłaceniu — zamiast przycisków płatności */
.q-paid {
  display: flex; flex-direction: column; align-items: flex-start; gap: 10px;
  border: 1px solid rgba(184, 137, 62, 0.45); background: rgba(184, 137, 62, 0.06);
  border-radius: var(--r-card); padding: 26px 24px;
}
.q-paid__check {
  width: 44px; height: 44px; border: 1.5px solid var(--color-brass);
  border-radius: 50%; display: flex; align-items: center; justify-content: center;
  color: var(--color-brass-dark); margin-bottom: 4px;
}
.q-paid__title { margin: 0; color: var(--color-ink); }
.q-paid__desc { margin: 0; font-size: 14px; line-height: 1.6; color: var(--color-ink-2); }
.q-opt__cta {
  display: inline-flex; align-items: center; justify-content: center; width: 100%;
  font-family: var(--font-mono); font-weight: 600; font-size: 12.5px;
  letter-spacing: 0.14em; text-transform: uppercase; padding: 14px 20px;
  margin-top: auto; border-radius: var(--r-control);
  transition: background var(--dur-base) var(--ease-out), border-color var(--dur-base) var(--ease-out), color var(--dur-base) var(--ease-out);
}
.q-opt__cta--solid { background: var(--color-brass-bright); color: var(--color-void); }
.q-opt--primary:hover .q-opt__cta--solid { background: var(--color-brass-light); }
.q-opt__cta--ghost { border: 1px solid var(--color-hair-ink); color: var(--color-ink); }
.q-opt:hover .q-opt__cta--ghost { border-color: var(--color-ink); }

/* ── error state ── */
.q-error { background: var(--color-onyx); color: var(--color-silver); min-height: 70vh; display: flex; align-items: center; padding-top: 120px; padding-bottom: 80px; }
.q-error__inner { text-align: center; }
.q-error__title { margin: 16px 0; color: var(--color-silver); }
.q-error__cta { margin-top: 28px; }

/* ── modal ── */
.q-modal {
  position: fixed; inset: 0; z-index: 1200; display: flex; align-items: center; justify-content: center;
  padding: 20px; background: rgba(8,9,12,0.6); backdrop-filter: blur(8px);
  opacity: 0; pointer-events: none; transition: opacity var(--dur-base) var(--ease-out);
}
.q-modal.is-open { opacity: 1; pointer-events: auto; }
.q-modal__box {
  position: relative; width: 100%; max-width: 30rem;
  background: var(--color-paper-2); border: 1px solid var(--color-hair-ink);
  border-radius: var(--r-shell); padding: clamp(28px, 4vw, 40px);
  box-shadow: var(--shadow-lift); transform: scale(0.96);
  transition: transform var(--dur-base) var(--ease-out);
}
.q-modal.is-open .q-modal__box { transform: scale(1); }
.q-modal__close {
  position: absolute; top: 18px; right: 18px; background: none; border: none;
  color: var(--color-ink-3); cursor: pointer; transition: color var(--dur-fast) var(--ease-out);
}
.q-modal__close:hover { color: var(--color-ink); }
.q-modal__title { margin: 12px 0 10px; color: var(--color-ink); }
.q-modal__lead { color: var(--color-ink-2); font-size: 15px; line-height: 1.6; margin: 0 0 22px; }
.q-modal__field {
  width: 100%; padding: 14px; font-family: var(--font-sans); font-size: 14px;
  color: var(--color-ink); background: var(--color-paper);
  border: 1px solid var(--color-hair-ink); border-radius: var(--r-control);
  resize: none; margin-bottom: 20px; transition: border-color var(--dur-base) var(--ease-out);
}
.q-modal__field:focus { outline: none; border-color: var(--color-brass); }
.q-modal__submit { width: 100%; justify-content: center; }
.q-modal__success { display: none; text-align: center; padding: 16px 0; }
.q-modal__check {
  width: 56px; height: 56px; border-radius: 50%; margin: 0 auto 20px;
  display: flex; align-items: center; justify-content: center;
  border: 1px solid var(--color-brass); color: var(--color-brass-dark);
}
.q-modal__close-btn { margin-top: 26px; }

/* ── responsive ── */
@media (max-width: 980px) {
  .q-grid { grid-template-columns: 1fr; gap: 48px; }
  .q-pay__sticky { position: static; }
}

@media (max-width: 640px) {
  .q-hero { padding-top: clamp(100px, 15vh, 140px); padding-bottom: clamp(52px, 11vw, 88px); }
  .q-h { gap: 10px; font-size: 1rem; }
  .q-opt { padding: 22px; }
  .q-modal__box { padding: 24px; }
}

@media (prefers-reduced-motion: reduce) {
  .q-hero__dot { animation: none; }
  .q-opt:hover { transform: none; }
}
</style>

<script>
// @ts-nocheck
document.addEventListener('DOMContentLoaded', () => {
  const container = document.getElementById('payment-options');
  if (!container) return;
  const token = container.dataset.token;
  const apiUrl = container.dataset.api;

  // ── Bramka zgód (clickwrap) ──
  const payBtns = container.querySelectorAll('.payment-btn');
  const cDocs = document.getElementById('consent-docs');
  const cWith = document.getElementById('consent-withdrawal');
  const hint = document.getElementById('consent-hint');
  const gateOk = () => !!(cDocs && cDocs.checked && cWith && cWith.checked);
  function applyGate() {
    const ok = gateOk();
    payBtns.forEach(b => { b.disabled = !ok; });
    if (hint) hint.style.display = ok ? 'none' : '';
  }
  cDocs?.addEventListener('change', applyGate);
  cWith?.addEventListener('change', applyGate);
  applyGate();

  // ── Modale dokumentów ──
  document.querySelectorAll('.q-consent__doc').forEach(b => {
    b.addEventListener('click', () => document.getElementById('docmodal-' + b.dataset.doc)?.classList.add('is-open'));
  });
  document.querySelectorAll('.q-docmodal').forEach(m => {
    m.addEventListener('click', (e) => { if (e.target === m) m.classList.remove('is-open'); });
    m.querySelector('[data-close-doc]')?.addEventListener('click', () => m.classList.remove('is-open'));
  });

  // ── Płatności ──
  payBtns.forEach(btn => {
    btn.addEventListener('click', async () => {
      if (!gateOk()) { applyGate(); return; }
      const btnText = btn.querySelector('.btn-text');
      const orig = btnText.innerHTML;
      btnText.innerHTML = 'Przetwarzanie&hellip;';
      payBtns.forEach(b => { b.disabled = true; });
      try {
        const res = await fetch(`${apiUrl}/api/quotes/checkout/${token}`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ paymentModel: btn.dataset.model, acceptDocuments: true, acceptWithdrawal: true })
        });
        const data = await res.json();
        if (data.url) { window.location.href = data.url; return; }
        alert('Błąd: ' + (data.error || 'Spróbuj ponownie.'));
      } catch { alert('Błąd połączenia z serwerem.'); }
      btnText.innerHTML = orig;
      applyGate();
    });
  });

  // ── Utrzymanie ──
  document.getElementById('maintenance-checkbox')?.addEventListener('change', async (e) => {
    try {
      await fetch(`${apiUrl}/api/quotes/client/${token}/maintenance`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ wantsMaintenance: e.target.checked })
      });
    } catch {}
  });

  // ── Modal ──
  const modal = document.getElementById('change-modal');
  const show = (v) => modal.classList.toggle('is-open', v);
  document.getElementById('open-change-modal')?.addEventListener('click', () => show(true));
  document.getElementById('close-change-modal')?.addEventListener('click', () => show(false));
  document.getElementById('close-success-modal')?.addEventListener('click', () => show(false));
  modal?.addEventListener('click', (e) => { if (e.target === modal) show(false); });

  document.getElementById('submit-change')?.addEventListener('click', async () => {
    const field = document.getElementById('change-message');
    const msg = field.value.trim();
    if (!msg) { alert('Wpisz treść uwag.'); return; }
    const btn = document.getElementById('submit-change');
    const label = btn.querySelector('.nb-btn__label');
    const orig = label.innerHTML;
    label.innerHTML = 'Wysyłanie&hellip;';
    btn.disabled = true;
    try {
      const res = await fetch(`${apiUrl}/api/quotes/request-change/${token}`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ message: msg })
      });
      if (res.ok) {
        document.getElementById('change-form-state').style.display = 'none';
        document.getElementById('change-success-state').style.display = 'block';
        return;
      }
      const d = await res.json();
      alert('Błąd: ' + (d.error || 'Spróbuj ponownie.'));
    } catch { alert('Błąd połączenia.'); }
    label.innerHTML = orig;
    btn.disabled = false;
  });
});
</script>
