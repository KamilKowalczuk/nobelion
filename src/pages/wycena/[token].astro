.q-consent__check span:last-child { font-size: 12.5px; line-height: 1.55; color: var(--color-ink-2); }
.q-consent__hint { margin: 0; text-align: center; font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.04em; color: var(--color-ink-4); }

/* ── modal dokumentu prawnego ── */
.q-docmodal {
  position: fixed; inset: 0; z-index: 1200; display: none;
  align-items: center; justify-content: center; padding: 20px;
