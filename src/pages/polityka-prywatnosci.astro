---
import LegalLayout from '../layouts/LegalLayout.astro';
import { renderMarkdown } from '../lib/markdown';

export const prerender = false;

const apiUrl = (process.env.PAYLOAD_API_URL || import.meta.env.PAYLOAD_API_URL || 'http://localhost:3001').replace(/\/$/, '');
let title = 'Polityka prywatności';
let htmlContent = '<p>Brak dostępnego dokumentu lub błąd ładowania.</p>';

try {
  const res = await fetch(`${apiUrl}/api/documents/public`);
  if (res.ok) {
    const data = await res.json();
    const doc = data.documents?.find((d: any) => d.docType === 'polityka-prywatnosci');
    if (doc) {
      title = doc.title || 'Polityka prywatności';
      htmlContent = renderMarkdown(doc.content);
    }
  }
} catch (e) {
  console.error("Błąd ładowania polityki prywatności:", e);
}
---

<LegalLayout title={title}>
  <div set:html={htmlContent} />
</LegalLayout>
