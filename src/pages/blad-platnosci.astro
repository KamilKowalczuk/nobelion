---
import Layout from '../layouts/Layout.astro';
import ClosingPage from '../components/core/ClosingPage.astro';
import Footer from '../components/sections/Footer.astro';
---

<Layout title="Błąd płatności | Nobelion" noindex={true}>
    <ClosingPage
        icon="pause"
        eyebrow="Płatność przerwana"
        title="Nic się nie stało."
        body="Płatność nie została pobrana — z Twojego konta nie zszedł ani grosz. Link do wyceny w Twoim mailu dalej działa, więc możesz wrócić i dokończyć, kiedy będziesz gotowy. Bez pośpiechu, wycena poczeka."
        note="Coś poszło nie tak po stronie płatności albo masz pytania do wyceny? Odpisz na maila z wyceną lub napisz bezpośrednio — pomożemy."
    >
        <Fragment slot="actions">
            <a href="mailto:kontakt@nobelion.pl" class="nb-btn nb-btn--primary nb-btn--lg"><span class="nb-btn__label">Napisz do nas</span></a>
            <a href="/" class="nb-btn nb-btn--ghost-light nb-btn--lg"><span class="nb-btn__label">Strona główna</span></a>
        </Fragment>
    </ClosingPage>

    <Footer />
</Layout>
