---
import Layout from './Layout.astro';
import Footer from '../components/sections/Footer.astro';
import ScrollChoreography from '../components/core/ScrollChoreography.svelte';

export interface Props {
  title: string;
}

const { title } = Astro.props;
---

<Layout title={`${title} | Nobelion`}>
  <ScrollChoreography client:idle />
  
  <div class="relative z-10 bg-paper rounded-b-shell shadow-[0_10px_40px_-10px_rgba(0,0,0,0.08)]">
    {/* ───────── ONYX HERO BAND ───────── */}
    <section class="relative overflow-hidden pt-[clamp(140px,16vw,200px)] pb-[clamp(80px,12vw,150px)]">
      <div class="absolute inset-0 bg-onyx z-0" aria-hidden="true">
        <div class="absolute w-[60%] h-[60%] top-0 left-[20%] bg-[radial-gradient(circle,var(--color-brass-glow)_0%,transparent_60%)] opacity-15 pointer-events-none"></div>
        <div class="absolute inset-0 pointer-events-none opacity-25 bg-[linear-gradient(rgba(255,255,255,0.025)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.025)_1px,transparent_1px)] bg-[size:64px_64px] [mask-image:radial-gradient(ellipse_80%_70%_at_50%_40%,#000_30%,transparent_75%)] [-webkit-mask-image:radial-gradient(ellipse_80%_70%_at_50%_40%,#000_30%,transparent_75%)]"></div>
      </div>
      <div class="wrap relative z-10">
        <div class="inline-flex items-center gap-[10px] mb-[26px]">
          <span class="w-[7px] h-[7px] rounded-full bg-brass-bright shadow-[0_0_12px_1px_var(--color-brass-glow)] animate-[q-pulse_2.6s_cubic-bezier(0.65,0,0.35,1)_infinite]"></span>
          <span class="eyebrow">Dokument Prawny</span>
        </div>
        <h1 class="font-heading font-bold uppercase leading-[1.04] tracking-[0.04em] text-silver m-0 text-[clamp(28px,5vw,68px)] max-w-[16ch] break-words">
          {title}
        </h1>
        <div class="mt-[32px]">
          <a href="/" class="nb-btn nb-btn--ghost nb-btn--md">
            <span class="nb-btn__label">← Wróć na stronę główną</span>
          </a>
        </div>
      </div>
    </section>

    {/* ───────── LIGHT BODY (overlapping panel) ───────── */}
    <section class="bg-paper pt-[clamp(56px,7vw,96px)] pb-[clamp(80px,10vw,120px)]">
      <div class="max-w-[800px] mx-auto px-[clamp(24px,5vw,40px)]">
        <div class="rt">
          <slot />
        </div>
      </div>
    </section>
  </div>

  <Footer />
</Layout>
