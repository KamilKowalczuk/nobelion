---
import '../styles/global.css';
import { siteConfig } from '../data/content';
import SmoothScroll from '../components/core/SmoothScroll.svelte';
import LegalSystem from '../components/core/LegalSystem.svelte';
import CookieConsent from '../components/core/CookieConsent.astro';

// === FONTY (self-hosted, tylko niezbędne wagi) ===
import '@fontsource/cinzel/400.css';
import '@fontsource/cinzel/700.css';

import '@fontsource/manrope/300.css';
import '@fontsource/manrope/400.css';
import '@fontsource/manrope/600.css';

import '@fontsource/jetbrains-mono/400.css';

// GTM i baner cookie aktywują się tylko, gdy PUBLIC_GTM_ID jest ustawione.
// UWAGA: ta deklaracja musi stać PO wszystkich importach — const wpleciony
// między importy wywala kompilator Astro ("Syntax error" przy buildzie).
const gtmId = import.meta.env.PUBLIC_GTM_ID || '';

export interface Props {
    title?: string;
    description?: string;
    canonical?: string;
    ogTitle?: string;
    ogDescription?: string;
    ogImage?: string;
    twitterTitle?: string;
    twitterDescription?: string;
    noindex?: boolean;
}

const {
    title = siteConfig.title,
    description = siteConfig.description,
    canonical = 'https://nobelion.pl/',
    ogTitle = 'NOBELION | Automatyzacje AI i Systemy dla Firm',
    ogDescription = 'Projektujemy automatyzacje AI i strony internetowe dla firm, które chcą rosnąć bez zatrudniania kolejnych ludzi.',
    ogImage = 'https://nobelion.pl/og-image-onyx.jpg',
    twitterTitle = 'NOBELION | Automatyzacje AI i Systemy dla Firm',
    twitterDescription = 'Projektujemy automatyzacje AI dla polskich firm. Brief w 2 minuty, plan i wycena w 24 godziny.',
    noindex = false,
} = Astro.props;

// Na stronie głównej linki menu to kotwice (#sekcja) — smooth-scroll.
// Na podstronach (np. /wycena/...) tych sekcji nie ma, więc kierujemy na
// stronę główną z kotwicą (/#sekcja), żeby przejść tam i przewinąć.
const isHome = Astro.url.pathname === '/';
const sec = (id: string) => (isHome ? `#${id}` : `/#${id}`);
const homeHref = isHome ? '#hero' : '/';
---
<!doctype html>
<html lang="pl">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="generator" content={Astro.generator} />

        <title>{title}</title>

        <meta name="description" content={description}>
        <meta name="author" content="Nobelion Sp. z o.o.">
        <meta name="keywords" content="automatyzacja AI, automatyzacje dla firm, agencja AI, strony internetowe, oprogramowanie na zamówienie, automatyzacja procesów, bot mailingowy, integracje API, custom software, automatyzacja sprzedaży, automatyzacja księgowości">

        <link rel="canonical" href={canonical}>

        {noindex ? (
            <meta name="robots" content="noindex, nofollow">
        ) : (
            <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1">
            <meta name="googlebot" content="index, follow">
        )}

        <meta property="og:locale" content="pl_PL">
        <meta property="og:type" content="website">
        <meta property="og:title" content={ogTitle}>
        <meta property="og:description" content={ogDescription}>
        <meta property="og:url" content={canonical}>
        <meta property="og:site_name" content="NOBELION">
        <meta property="og:image" content={ogImage}>
        <meta property="og:image:width" content="1200">
        <meta property="og:image:height" content="630">
        <meta property="og:image:alt" content="Nobelion, automatyzacje AI dla firm">

        <meta name="twitter:card" content="summary_large_image">
        <meta name="twitter:title" content={twitterTitle}>
        <meta name="twitter:description" content={twitterDescription}>
        <meta name="twitter:image" content={ogImage}>

        <script is:inline define:vars={{ gtmId }}>
            /* Google Consent Mode v2 — domyślnie wszystko "denied" PRZED
               załadowaniem GTM. Zgody aktualizuje baner cookie (CookieConsent).
               Bez PUBLIC_GTM_ID skrypt nie robi nic. */
            if (gtmId) {
                window.dataLayer = window.dataLayer || [];
                window.gtag = function gtag() { window.dataLayer.push(arguments); };
                window.gtag('consent', 'default', {
                    ad_storage: 'denied',
                    ad_user_data: 'denied',
                    ad_personalization: 'denied',
                    analytics_storage: 'denied',
                    functionality_storage: 'denied',
                    personalization_storage: 'denied',
                    security_storage: 'granted',
                    wait_for_update: 500
                });
                window.gtag('set', 'ads_data_redaction', true);

                /* Google Tag Manager */
                (function (w, d, s, l, i) {
                    w[l] = w[l] || []; w[l].push({ 'gtm.start': new Date().getTime(), event: 'gtm.js' });
                    var f = d.getElementsByTagName(s)[0], j = d.createElement(s),
                        dl = l !== 'dataLayer' ? '&l=' + l : '';
                    j.async = true; j.src = 'https://www.googletagmanager.com/gtm.js?id=' + i + dl;
                    f.parentNode.insertBefore(j, f);
                })(window, document, 'script', 'dataLayer', gtmId);
            }
        </script>

        <meta name="theme-color" content="#050505">
        <meta name="msapplication-TileColor" content="#0B101C">
        <link rel="icon" type="image/svg+xml" href="/favicon.svg">
        <link rel="mask-icon" href="/safari-pinned-tab.svg" color="#C5A059">

        <script is:inline type="application/ld+json" set:html={JSON.stringify({
            "@context": "https://schema.org",
            "@type": "ProfessionalService",
            "name": "Nobelion Sp. z o.o.",
            "alternateName": "Nobelion",
            "url": "https://nobelion.pl/",
            "logo": "https://nobelion.pl/favicon.svg",
            "description": "Agencja projektowania automatyzacji AI, stron internetowych oraz oprogramowania na zamówienie dla polskich firm. Od briefu do wdrożenia w jednym ekosystemie.",
            "foundingDate": "2020",
            "priceRange": "$$$",
            "address": {
                "@type": "PostalAddress",
                "streetAddress": "Ul. Pamiątkowa 2",
                "addressLocality": "Poznań",
                "postalCode": "61-512",
                "addressCountry": "PL"
            },
            "contactPoint": {
                "@type": "ContactPoint",
                "email": "kontakt@nobelion.pl",
                "contactType": "customer service",
                "areaServed": ["PL", "EU"],
                "availableLanguage": ["Polish", "English"]
            },
            "areaServed": {
                "@type": "Country",
                "name": "Poland"
            },
            "serviceType": [
                "Automatyzacje AI",
                "Strony internetowe",
                "Oprogramowanie na zamówienie",
                "Integracje systemów",
                "Custom software development"
            ],
            "identifier": [
                { "@type": "PropertyValue", "propertyID": "NIP", "value": "7831898094" },
                { "@type": "PropertyValue", "propertyID": "KRS", "value": "0001088524" },
                { "@type": "PropertyValue", "propertyID": "REGON", "value": "527810001" }
            ]
        })} />

        <script is:inline type="application/ld+json" set:html={JSON.stringify({
            "@context": "https://schema.org",
            "@type": "FAQPage",
            "mainEntity": [
                {
                    "@type": "Question",
                    "name": "Czym zajmuje się Nobelion?",
                    "acceptedAnswer": {
                        "@type": "Answer",
                        "text": "Projektujemy automatyzacje AI, strony internetowe oraz oprogramowanie na zamówienie dla polskich firm. Każdy projekt zaczynamy od briefu i konkretnej wyceny w ciągu 24 do 48 godzin."
                    }
                },
                {
                    "@type": "Question",
                    "name": "Ile kosztuje wdrożenie automatyzacji?",
                    "acceptedAnswer": {
                        "@type": "Answer",
                        "text": "Każdy projekt jest inny, dlatego wycena jest zawsze indywidualna. Po wypełnieniu briefu otrzymują Państwo plan i konkretną kwotę w ciągu 24 do 48 godzin. Bez ukrytych kosztów."
                    }
                },
                {
                    "@type": "Question",
                    "name": "Czy muszę znać się na technologii?",
                    "acceptedAnswer": {
                        "@type": "Answer",
                        "text": "Nie. Naszą rolą jest tłumaczenie złożonych spraw na zwykły język. Brief jest po polsku, plan jest po polsku. Wystarczy, że wiesz, co Cię uwiera w codziennej pracy."
                    }
                },
                {
                    "@type": "Question",
                    "name": "Jak długo trwa projekt?",
                    "acceptedAnswer": {
                        "@type": "Answer",
                        "text": "Najczęściej od dwóch do sześciu tygodni, w zależności od skali. Proste integracje uruchamiamy w ciągu kilku dni. Większe systemy budujemy etapami."
                    }
                }
            ]
        })} />
    </head>
    <body class="bg-paper text-ink-2 selection:bg-brass/30 selection:text-white relative">
        {gtmId && (
            <noscript>
                <iframe
                    src={`https://www.googletagmanager.com/ns.html?id=${gtmId}`}
                    height="0"
                    width="0"
                    style="display:none;visibility:hidden"
                    title="Google Tag Manager"
                ></iframe>
            </noscript>
        )}

        <SmoothScroll client:only />
        <LegalSystem client:idle />
        {gtmId && <CookieConsent />}

        <div class="noise-overlay"></div>

        <!-- Skip to content (accessibility) -->
        <a
            href="#main-content"
            class="skip-link sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-100 focus:px-4 focus:py-2 focus:bg-brass focus:text-void focus:font-mono focus:text-xs focus:tracking-[0.3em] focus:uppercase focus:outline-none"
        >
            Przejdź do treści
        </a>

        <!-- ============================================================
             GŁÓWNY HEADER NAWIGACJI
             - Transparent na hero, light-glass po scrollu
             - Logo lewo | Nav środek | CTA prawo
        ============================================================ -->
        <header id="site-header" class="fixed top-0 left-0 right-0 z-[1000] transition-[background,box-shadow,border-color] duration-300 ease-[cubic-bezier(0.16,1,0.3,1)] border-b border-transparent [&.is-solid]:bg-[#F7F4ED]/82 [&.is-solid]:backdrop-blur-[14px] [&.is-solid]:border-ink/10 [&.is-solid]:shadow-[0_1px_0_rgba(21,23,29,0.02)] group motion-reduce:transition-none">
            <div class="flex items-center justify-between h-[72px] wrap">

                <a
                    id="header-logo"
                    href={homeHref}
                    class="flex items-center gap-[12px] no-underline"
                    aria-label="Nobelion — wróć na górę strony"
                >
                    <img src="/logo-icon.svg" alt="" aria-hidden="true" class="w-[38px] h-[38px] object-contain" width="38" height="38" />
                    <span class="font-heading font-bold text-[21px] tracking-[0.18em] uppercase text-silver transition-colors duration-300 group-[.is-solid]:text-ink">NOBELION</span>
                </a>

                <nav class="hidden max-[860px]:hidden md:flex items-center gap-[34px]" aria-label="Główna nawigacja">
                    <a href={sec('oferta')} class="relative py-[6px] font-mono text-[13px] tracking-[0.04em] text-silver-soft transition-colors duration-[180ms] no-underline hover:text-white after:content-[''] after:absolute after:left-0 after:bottom-0 after:h-[1px] after:w-0 after:bg-brass-bright after:transition-[width] after:duration-300 after:ease-[cubic-bezier(0.16,1,0.3,1)] hover:after:w-full group-[.is-solid]:text-ink-2 group-[.is-solid]:hover:text-brass group-[.is-solid]:after:bg-brass motion-reduce:after:transition-none" data-section="oferta">OFERTA</a>
                    <a href={sec('wdrozenia')} class="relative py-[6px] font-mono text-[13px] tracking-[0.04em] text-silver-soft transition-colors duration-[180ms] no-underline hover:text-white after:content-[''] after:absolute after:left-0 after:bottom-0 after:h-[1px] after:w-0 after:bg-brass-bright after:transition-[width] after:duration-300 after:ease-[cubic-bezier(0.16,1,0.3,1)] hover:after:w-full group-[.is-solid]:text-ink-2 group-[.is-solid]:hover:text-brass group-[.is-solid]:after:bg-brass motion-reduce:after:transition-none" data-section="wdrozenia">WDROŻENIA</a>
                    <a href={sec('proces')} class="relative py-[6px] font-mono text-[13px] tracking-[0.04em] text-silver-soft transition-colors duration-[180ms] no-underline hover:text-white after:content-[''] after:absolute after:left-0 after:bottom-0 after:h-[1px] after:w-0 after:bg-brass-bright after:transition-[width] after:duration-300 after:ease-[cubic-bezier(0.16,1,0.3,1)] hover:after:w-full group-[.is-solid]:text-ink-2 group-[.is-solid]:hover:text-brass group-[.is-solid]:after:bg-brass motion-reduce:after:transition-none" data-section="proces">PROCES</a>
                    <a href={sec('bezpieczenstwo')} class="relative py-[6px] font-mono text-[13px] tracking-[0.04em] text-silver-soft transition-colors duration-[180ms] no-underline hover:text-white after:content-[''] after:absolute after:left-0 after:bottom-0 after:h-[1px] after:w-0 after:bg-brass-bright after:transition-[width] after:duration-300 after:ease-[cubic-bezier(0.16,1,0.3,1)] hover:after:w-full group-[.is-solid]:text-ink-2 group-[.is-solid]:hover:text-brass group-[.is-solid]:after:bg-brass motion-reduce:after:transition-none" data-section="bezpieczenstwo">BEZPIECZEŃSTWO</a>
                    <a href={sec('faq')} class="relative py-[6px] font-mono text-[13px] tracking-[0.04em] text-silver-soft transition-colors duration-[180ms] no-underline hover:text-white after:content-[''] after:absolute after:left-0 after:bottom-0 after:h-[1px] after:w-0 after:bg-brass-bright after:transition-[width] after:duration-300 after:ease-[cubic-bezier(0.16,1,0.3,1)] hover:after:w-full group-[.is-solid]:text-ink-2 group-[.is-solid]:hover:text-brass group-[.is-solid]:after:bg-brass motion-reduce:after:transition-none" data-section="faq">FAQ</a>
                </nav>

                <div class="flex items-center gap-[14px]">
                    <a href={sec('brief')} class="hidden max-[860px]:hidden md:inline-flex items-center gap-[9px] font-mono text-[12px] tracking-[0.12em] uppercase text-void bg-brass-bright py-[11px] px-[18px] transition-[background,box-shadow] duration-[180ms] no-underline rounded-[9px] hover:bg-brass-light hover:shadow-[0_12px_32px_-10px_var(--color-brass-glow)] group-[.is-solid]:bg-ink group-[.is-solid]:text-paper group-[.is-solid]:hover:bg-brass group-[.is-solid]:hover:text-void group-hover/btn:translate-x-1 nav-cta group/btn">
                        <span>WYPEŁNIJ BRIEF</span>
                        <svg class="inline-flex transition-transform duration-300 ease-[cubic-bezier(0.16,1,0.3,1)] group-hover/btn:translate-x-1" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="square" stroke-linejoin="miter">
                            <path d="M5 12 H19 M13 6 L19 12 L13 18" />
                        </svg>
                    </a>
                    <button
                        id="mobile-menu-btn"
                        class="hidden max-[860px]:flex flex-col gap-[5px] bg-transparent border-none cursor-pointer p-[8px]"
                        aria-label="Otwórz menu nawigacyjne"
                        aria-expanded="false"
                        aria-controls="mobile-menu"
                        type="button"
                    >
                        <span class="w-[22px] h-[1.5px] bg-silver transition-colors duration-300 group-[.is-solid]:bg-ink"></span>
                        <span class="w-[22px] h-[1.5px] bg-silver transition-colors duration-300 group-[.is-solid]:bg-ink"></span>
                        <span class="w-[22px] h-[1.5px] bg-silver transition-colors duration-300 group-[.is-solid]:bg-ink"></span>
                    </button>
                </div>
            </div>

            <div id="mobile-menu" class="hidden max-[860px]:flex flex-col bg-onyx border-t border-white/10 max-h-0 overflow-hidden transition-[max-height] duration-300 ease-[cubic-bezier(0.16,1,0.3,1)] [&.open]:max-h-[420px] motion-reduce:transition-none">
                <a href={sec('oferta')} class="py-[16px] px-[24px] font-mono text-[14px] tracking-[0.08em] text-silver-soft border-b border-white/5 no-underline" data-section="oferta">OFERTA</a>
                <a href={sec('wdrozenia')} class="py-[16px] px-[24px] font-mono text-[14px] tracking-[0.08em] text-silver-soft border-b border-white/5 no-underline" data-section="wdrozenia">WDROŻENIA</a>
                <a href={sec('proces')} class="py-[16px] px-[24px] font-mono text-[14px] tracking-[0.08em] text-silver-soft border-b border-white/5 no-underline" data-section="proces">PROCES</a>
                <a href={sec('bezpieczenstwo')} class="py-[16px] px-[24px] font-mono text-[14px] tracking-[0.08em] text-silver-soft border-b border-white/5 no-underline" data-section="bezpieczenstwo">BEZPIECZEŃSTWO</a>
                <a href={sec('faq')} class="py-[16px] px-[24px] font-mono text-[14px] tracking-[0.08em] text-silver-soft border-b border-white/5 no-underline" data-section="faq">FAQ</a>
                <a href={sec('brief')} class="py-[16px] px-[24px] font-mono text-[14px] tracking-[0.08em] border-b border-white/5 no-underline !text-brass-bright">WYPEŁNIJ BRIEF</a>
            </div>
        </header>

        <main id="main-content" tabindex="-1">
            <slot />
        </main>


        <!-- Floating CTA: pojawia się po opuszczeniu hero -->
        <a
            id="floating-cta"
            href={sec('brief')}
            class="floating-cta fixed bottom-6 right-6 md:bottom-10 md:right-10 z-50 inline-flex items-center gap-3 pl-6 pr-7 py-4 bg-brass text-void font-heading font-bold text-xs md:text-sm tracking-[0.2em] uppercase opacity-0 pointer-events-none transition-all duration-300 ease-out"
            style="border-radius: var(--r-control);"
            aria-label="Rozpocznij brief"
        >
            <span class="floating-cta-dot inline-block w-2 h-2 bg-void rounded-full"></span>
            <span>ZACZNIJ BRIEF</span>
        </a>

        <script>
            // === HEADER: light-glass po ~50px scrolla ===
            const siteHeader = document.getElementById('site-header');

            if (siteHeader) {
                let rafPending = false;
                const checkScroll = () => {
                    siteHeader.classList.toggle('is-solid', window.scrollY > 50);
                    rafPending = false;
                };
                window.addEventListener('scroll', () => {
                    if (!rafPending) {
                        rafPending = true;
                        requestAnimationFrame(checkScroll);
                    }
                }, { passive: true });
                checkScroll();
            }

            // === MOBILE MENU ===
            const mobileMenuBtn = document.getElementById('mobile-menu-btn');
            const mobileMenu = document.getElementById('mobile-menu');
            let isMenuOpen = false;

            function toggleMobileMenu(open: boolean) {
                isMenuOpen = open;
                mobileMenuBtn?.setAttribute('aria-expanded', String(open));
                mobileMenuBtn?.classList.toggle('open', open);
                mobileMenu?.classList.toggle('open', open);
                document.body.style.overflow = open ? 'hidden' : '';
                if (open) (mobileMenu as HTMLElement)?.focus();
            }

            mobileMenuBtn?.addEventListener('click', () => toggleMobileMenu(!isMenuOpen));

            mobileMenu?.querySelectorAll('a').forEach(link => {
                link.addEventListener('click', () => toggleMobileMenu(false));
            });

            document.addEventListener('keydown', (e: KeyboardEvent) => {
                if (e.key === 'Escape' && isMenuOpen) toggleMobileMenu(false);
            });

            // === FLOATING CTA ===
            const floatingCta = document.getElementById('floating-cta');
            const heroEl = document.getElementById('hero');
            const briefEl = document.getElementById('brief');
            const footerEl = document.querySelector('.nb-footer');

            if (floatingCta && heroEl) {
                let heroVisible = true;
                let briefVisible = false;
                let bottomVisible = false;

                const refreshCta = () => {
                    const show = !heroVisible && !briefVisible && !bottomVisible;
                    floatingCta.classList.toggle('opacity-0', !show);
                    floatingCta.classList.toggle('pointer-events-none', !show);
                    floatingCta.classList.toggle('opacity-100', show);
                };

                new IntersectionObserver(([entry]) => {
                    heroVisible = entry.isIntersecting;
                    refreshCta();
                }, { threshold: 0.1 }).observe(heroEl);

                if (briefEl) {
                    new IntersectionObserver(([entry]) => {
                        briefVisible = entry.isIntersecting;
                        refreshCta();
                    }, { threshold: 0.05 }).observe(briefEl);
                }

                if (footerEl) {
                    new IntersectionObserver(([entry]) => {
                        bottomVisible = entry.isIntersecting;
                        refreshCta();
                    }, { threshold: 0.05 }).observe(footerEl);
                }
            }
        </script>

        <style is:global>
            section[id] {
                scroll-margin-top: 5rem;
            }
        </style>
    </body>
</html>
