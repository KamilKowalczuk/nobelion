---
import '../styles/global.css';
import { siteConfig } from '../data/content';
import SmoothScroll from '../components/core/SmoothScroll.svelte';
import LegalSystem from '../components/core/LegalSystem.svelte';

// === FONTY (self-hosted, tylko niezbędne wagi) ===
import '@fontsource/cinzel/400.css';
import '@fontsource/cinzel/700.css';

import '@fontsource/manrope/300.css';
import '@fontsource/manrope/400.css';
import '@fontsource/manrope/600.css';

import '@fontsource/jetbrains-mono/400.css';

// Na stronie głównej linki menu to kotwice (#sekcja) — smooth-scroll.
// Na podstronach (np. /wycena/...) tych sekcji nie ma, więc kierujemy na
// stronę główną z kotwicą (/#sekcja), żeby przejść tam i przewinąć.
const isHome = Astro.url.pathname === '/';
const sec = (id: string) => (isHome ? `#${id}` : `/#${id}`);
const homeHref = isHome ? '#hero' : '/';
---
<!doctype html>
<html lang="pl">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="generator" content={Astro.generator} />

        <title>{siteConfig.title}</title>

        <meta name="description" content={siteConfig.description}>
        <meta name="author" content="Nobelion Sp. z o.o.">
        <meta name="keywords" content="automatyzacja AI, automatyzacje dla firm, agencja AI, strony internetowe, oprogramowanie na zamówienie, automatyzacja procesów, bot mailingowy, integracje API, custom software, automatyzacja sprzedaży, automatyzacja księgowości">

        <link rel="canonical" href="https://nobelion.pl/">

        <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1">
        <meta name="googlebot" content="index, follow">

        <meta property="og:locale" content="pl_PL">
        <meta property="og:type" content="website">
        <meta property="og:title" content="NOBELION | Automatyzacje AI i Systemy dla Firm">
        <meta property="og:description" content="Projektujemy automatyzacje AI i strony internetowe dla firm, które chcą rosnąć bez zatrudniania kolejnych ludzi.">
        <meta property="og:url" content="https://nobelion.pl/">
        <meta property="og:site_name" content="NOBELION">
        <meta property="og:image" content="https://nobelion.pl/og-image-onyx.jpg">
        <meta property="og:image:width" content="1200">
        <meta property="og:image:height" content="630">
        <meta property="og:image:alt" content="Nobelion, automatyzacje AI dla firm">

        <meta name="twitter:card" content="summary_large_image">
        <meta name="twitter:title" content="NOBELION | Automatyzacje AI i Systemy dla Firm">
        <meta name="twitter:description" content="Projektujemy automatyzacje AI dla polskich firm. Brief w 2 minuty, plan i wycena w 24 godziny.">
        <meta name="twitter:image" content="https://nobelion.pl/og-image-onyx.jpg">

        <meta name="theme-color" content="#050505">
        <meta name="msapplication-TileColor" content="#0B101C">
        <link rel="icon" type="image/svg+xml" href="/favicon.svg">
        <link rel="mask-icon" href="/safari-pinned-tab.svg" color="#C5A059">

        <script is:inline type="application/ld+json" set:html={JSON.stringify({
            "@context": "https://schema.org",
            "@type": "ProfessionalService",
            "name": "Nobelion Sp. z o.o.",
            "alternateName": "Nobelion",
            "url": "https://nobelion.pl/",
            "logo": "https://nobelion.pl/favicon.svg",
            "description": "Agencja projektowania automatyzacji AI, stron internetowych oraz oprogramowania na zamówienie dla polskich firm. Od briefu do wdrożenia w jednym ekosystemie.",
            "foundingDate": "2020",
            "priceRange": "$$$",
            "address": {
                "@type": "PostalAddress",
                "streetAddress": "Ul. Pamiątkowa 2",
                "addressLocality": "Poznań",
                "postalCode": "61-512",
                "addressCountry": "PL"
            },
            "contactPoint": {
                "@type": "ContactPoint",
                "email": "kontakt@nobelion.pl",
                "contactType": "customer service",
                "areaServed": ["PL", "EU"],
                "availableLanguage": ["Polish", "English"]
            },
            "areaServed": {
                "@type": "Country",
                "name": "Poland"
            },
            "serviceType": [
                "Automatyzacje AI",
                "Strony internetowe",
                "Oprogramowanie na zamówienie",
                "Integracje systemów",
                "Custom software development"
            ],
            "identifier": [
                { "@type": "PropertyValue", "propertyID": "NIP", "value": "7831898094" },
                { "@type": "PropertyValue", "propertyID": "KRS", "value": "0001088524" },
                { "@type": "PropertyValue", "propertyID": "REGON", "value": "527810001" }
            ]
        })} />

        <script is:inline type="application/ld+json" set:html={JSON.stringify({
            "@context": "https://schema.org",
            "@type": "FAQPage",
            "mainEntity": [
                {
                    "@type": "Question",
                    "name": "Czym zajmuje się Nobelion?",
                    "acceptedAnswer": {
                        "@type": "Answer",
                        "text": "Projektujemy automatyzacje AI, strony internetowe oraz oprogramowanie na zamówienie dla polskich firm. Każdy projekt zaczynamy od briefu i konkretnej wyceny w ciągu 24 do 48 godzin."
                    }
                },
                {
                    "@type": "Question",
                    "name": "Ile kosztuje wdrożenie automatyzacji?",
                    "acceptedAnswer": {
                        "@type": "Answer",
                        "text": "Każdy projekt jest inny, dlatego wycena jest zawsze indywidualna. Po wypełnieniu briefu otrzymują Państwo plan i konkretną kwotę w ciągu 24 do 48 godzin. Bez ukrytych kosztów."
                    }
                },
                {
                    "@type": "Question",
                    "name": "Czy muszę znać się na technologii?",
                    "acceptedAnswer": {
                        "@type": "Answer",
                        "text": "Nie. Naszą rolą jest tłumaczenie złożonych spraw na zwykły język. Brief jest po polsku, plan jest po polsku. Wystarczy, że wiesz, co Cię uwiera w codziennej pracy."
                    }
                },
                {
                    "@type": "Question",
                    "name": "Jak długo trwa projekt?",
                    "acceptedAnswer": {
                        "@type": "Answer",
                        "text": "Najczęściej od dwóch do sześciu tygodni, w zależności od skali. Proste integracje uruchamiamy w ciągu kilku dni. Większe systemy budujemy etapami."
                    }
                }
            ]
        })} />
    </head>
    <body class="bg-paper text-ink-2 selection:bg-brass/30 selection:text-white relative">
        <SmoothScroll client:only />
        <LegalSystem client:load />

        <div class="noise-overlay"></div>

        <!-- Skip to content (accessibility) -->
        <a
            href="#main-content"
            class="skip-link sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-100 focus:px-4 focus:py-2 focus:bg-brass focus:text-void focus:font-mono focus:text-xs focus:tracking-[0.3em] focus:uppercase focus:outline-none"
        >
            Przejdź do treści
        </a>

        <!-- ============================================================
             GŁÓWNY HEADER NAWIGACJI
             - Transparent na hero, light-glass po scrollu
             - Logo lewo | Nav środek | CTA prawo
        ============================================================ -->
        <header id="site-header" class="nb-header">
            <div class="nb-header__inner wrap">

                <a
                    id="header-logo"
                    href={homeHref}
                    class="nb-brand"
                    aria-label="Nobelion — wróć na górę strony"
                >
                    <img src="/logo-icon.png" alt="" aria-hidden="true" class="nb-brand__mark" />
                    <span class="nb-brand__word">NOBELION</span>
                </a>

                <nav class="nb-nav" aria-label="Główna nawigacja">
                    <a href={sec('oferta')} class="nb-nav__link" data-section="oferta">OFERTA</a>
                    <a href={sec('wdrozenia')}    class="nb-nav__link" data-section="wdrozenia">WDROŻENIA</a>
                    <a href={sec('proces')}  class="nb-nav__link" data-section="proces">PROCES</a>
                    <a href={sec('bezpieczenstwo')} class="nb-nav__link" data-section="bezpieczenstwo">BEZPIECZEŃSTWO</a>
                    <a href={sec('faq')}      class="nb-nav__link" data-section="faq">FAQ</a>
                </nav>

                <div class="nb-header__actions">
                    <a href={sec('brief')} class="nb-header__cta">
                        <span>WYPEŁNIJ BRIEF</span>
                        <svg class="nb-header__icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="square" stroke-linejoin="miter">
                            <path d="M5 12 H19 M13 6 L19 12 L13 18" />
                        </svg>
                    </a>
                    <button
                        id="mobile-menu-btn"
                        class="nb-burger"
                        aria-label="Otwórz menu nawigacyjne"
                        aria-expanded="false"
                        aria-controls="mobile-menu"
                        type="button"
                    >
                        <span></span>
                        <span></span>
                        <span></span>
                    </button>
                </div>
            </div>

            <div id="mobile-menu" class="nb-mobile">
                <a href={sec('oferta')} class="mobile-nav-link" data-section="oferta">OFERTA</a>
                <a href={sec('wdrozenia')}    class="mobile-nav-link" data-section="wdrozenia">WDROŻENIA</a>
                <a href={sec('proces')}  class="mobile-nav-link" data-section="proces">PROCES</a>
                <a href={sec('bezpieczenstwo')} class="mobile-nav-link" data-section="bezpieczenstwo">BEZPIECZEŃSTWO</a>
                <a href={sec('faq')}      class="mobile-nav-link" data-section="faq">FAQ</a>
                <a href={sec('brief')} class="nb-mobile__cta">WYPEŁNIJ BRIEF</a>
            </div>
        </header>

        <main id="main-content" tabindex="-1">
            <slot />
        </main>


        <!-- Floating CTA: pojawia się po opuszczeniu hero -->
        <a
            id="floating-cta"
            href={sec('brief')}
            class="floating-cta fixed bottom-6 right-6 md:bottom-10 md:right-10 z-50 inline-flex items-center gap-3 pl-6 pr-7 py-4 bg-brass text-void font-heading font-bold text-xs md:text-sm tracking-[0.2em] uppercase opacity-0 pointer-events-none transition-all duration-300 ease-out"
            style="border-radius: var(--r-control);"
            aria-label="Rozpocznij brief"
        >
            <span class="floating-cta-dot inline-block w-2 h-2 bg-void rounded-full"></span>
            <span>ZACZNIJ BRIEF</span>
        </a>

        <script>
            // === HEADER: light-glass po ~50px scrolla ===
            const siteHeader = document.getElementById('site-header');

            if (siteHeader) {
                let rafPending = false;
                const checkScroll = () => {
                    siteHeader.classList.toggle('is-solid', window.scrollY > 50);
                    rafPending = false;
                };
                window.addEventListener('scroll', () => {
                    if (!rafPending) {
                        rafPending = true;
                        requestAnimationFrame(checkScroll);
                    }
                }, { passive: true });
                checkScroll();
            }

            // === MOBILE MENU ===
            const mobileMenuBtn = document.getElementById('mobile-menu-btn');
            const mobileMenu = document.getElementById('mobile-menu');
            let isMenuOpen = false;

            function toggleMobileMenu(open: boolean) {
                isMenuOpen = open;
                mobileMenuBtn?.setAttribute('aria-expanded', String(open));
                mobileMenuBtn?.classList.toggle('open', open);
                mobileMenu?.classList.toggle('open', open);
                document.body.style.overflow = open ? 'hidden' : '';
                if (open) (mobileMenu as HTMLElement)?.focus();
            }

            mobileMenuBtn?.addEventListener('click', () => toggleMobileMenu(!isMenuOpen));

            mobileMenu?.querySelectorAll('a').forEach(link => {
                link.addEventListener('click', () => toggleMobileMenu(false));
            });

            document.addEventListener('keydown', (e: KeyboardEvent) => {
                if (e.key === 'Escape' && isMenuOpen) toggleMobileMenu(false);
            });

            // === FLOATING CTA ===
            const floatingCta = document.getElementById('floating-cta');
            const heroEl = document.getElementById('hero');
            const briefEl = document.getElementById('brief');
            const footerEl = document.querySelector('.nb-footer');

            if (floatingCta && heroEl) {
                let heroVisible = true;
                let briefVisible = false;
                let bottomVisible = false;

                const refreshCta = () => {
                    const show = !heroVisible && !briefVisible && !bottomVisible;
                    floatingCta.classList.toggle('opacity-0', !show);
                    floatingCta.classList.toggle('pointer-events-none', !show);
                    floatingCta.classList.toggle('opacity-100', show);
                };

                new IntersectionObserver(([entry]) => {
                    heroVisible = entry.isIntersecting;
                    refreshCta();
                }, { threshold: 0.1 }).observe(heroEl);

                if (briefEl) {
                    new IntersectionObserver(([entry]) => {
                        briefVisible = entry.isIntersecting;
                        refreshCta();
                    }, { threshold: 0.05 }).observe(briefEl);
                }

                if (footerEl) {
                    new IntersectionObserver(([entry]) => {
                        bottomVisible = entry.isIntersecting;
                        refreshCta();
                    }, { threshold: 0.05 }).observe(footerEl);
                }
            }
        </script>

        <style is:global>
            /* ---------------- HEADER ---------------- */
            .nb-header{position:fixed;top:0;left:0;right:0;z-index:1000;transition:background 300ms cubic-bezier(0.16,1,0.3,1),box-shadow 300ms cubic-bezier(0.16,1,0.3,1),border-color 300ms;
            border-bottom:1px solid transparent;}
            .nb-header__inner{display:flex;align-items:center;justify-content:space-between;height:72px;}
            .nb-header.is-solid{background:rgba(247,244,237,0.82);backdrop-filter:blur(14px);-webkit-backdrop-filter:blur(14px);border-bottom-color:rgba(21,23,29,0.10);box-shadow:0 1px 0 rgba(21,23,29,0.02);}

            .nb-brand{display:flex;align-items:center;gap:12px;text-decoration:none;}
            .nb-brand__mark{width:38px;height:38px;object-fit:contain;}
            .nb-brand__word{font-family:var(--font-heading);font-weight:700;font-size:21px;letter-spacing:0.18em;text-transform:uppercase;color:var(--color-silver);transition:color 300ms;}
            .nb-header.is-solid .nb-brand__word{color:var(--color-ink);}

            .nb-nav{display:flex;align-items:center;gap:34px;}
            .nb-nav__link{font-family:var(--font-mono);font-size:13px;letter-spacing:0.04em;color:var(--color-silver-soft);position:relative;padding:6px 0;transition:color 180ms;text-decoration:none;}
            .nb-nav__link::after{content:"";position:absolute;left:0;bottom:0;height:1px;width:0;background:var(--color-brass-bright);transition:width 300ms cubic-bezier(0.16,1,0.3,1);}
            .nb-nav__link:hover{color:#fff;}
            .nb-nav__link:hover::after{width:100%;}
            .nb-header.is-solid .nb-nav__link{color:var(--color-ink-2);}
            .nb-header.is-solid .nb-nav__link:hover{color:var(--color-brass);}
            .nb-header.is-solid .nb-nav__link::after{background:var(--color-brass);}

            .nb-header__actions{display:flex;align-items:center;gap:14px;}
            .nb-header__cta{display:inline-flex;align-items:center;gap:9px;font-family:var(--font-mono);font-size:12px;letter-spacing:0.12em;text-transform:uppercase;color:var(--color-void);background:var(--color-brass-bright);padding:11px 18px;transition:background 180ms,box-shadow 300ms;text-decoration:none;border-radius:var(--r-control);}
            .nb-header__icon{display:inline-flex;transition:transform 300ms cubic-bezier(0.16,1,0.3,1);}
            .nb-header__cta:hover{background:var(--color-brass-light);box-shadow:0 12px 32px -10px var(--color-brass-glow);}
            .nb-header__cta:hover .nb-header__icon{transform:translateX(4px);}
            .nb-header.is-solid .nb-header__cta{background:var(--color-ink);color:var(--color-paper);}
            .nb-header.is-solid .nb-header__cta:hover{background:var(--color-brass);color:var(--color-void);}

            .nb-burger{display:none;flex-direction:column;gap:5px;background:none;border:none;cursor:pointer;padding:8px;}
            .nb-burger span{width:22px;height:1.5px;background:var(--color-silver);transition:background 300ms;}
            .nb-header.is-solid .nb-burger span{background:var(--color-ink);}

            .nb-mobile{display:none;flex-direction:column;background:var(--color-onyx);border-top:1px solid rgba(255,255,255,0.08);max-height:0;overflow:hidden;transition:max-height 300ms cubic-bezier(0.16,1,0.3,1);}
            .nb-mobile.open{max-height:420px;display:flex;}
            .nb-mobile a{padding:16px 24px;font-family:var(--font-mono);font-size:14px;letter-spacing:0.08em;color:var(--color-silver-soft);border-bottom:1px solid rgba(255,255,255,0.05);text-decoration:none;}
            .nb-mobile__cta{color:var(--color-brass-bright)!important;}

            @media(max-width:860px){
            .nb-nav{display:none;}
            .nb-header__cta{display:none;}
            .nb-burger{display:flex;}
            }

            /* ---------- Mercury-style overlapping panels ---------- */
            .nb-panel{position:relative;z-index:1;
            border-top-left-radius:clamp(22px,2.6vw,44px);
            border-top-right-radius:clamp(22px,2.6vw,44px);
            margin-top:clamp(-44px,-2.6vw,-22px);
            box-shadow:0 -22px 48px -28px rgba(21,23,29,0.16);
            overflow: hidden;
            }
            .nb-panel--dark{box-shadow:0 -28px 70px -32px rgba(0,0,0,0.55);}
            .nb-panel::before{content:"";position:absolute;top:0;left:0;right:0;height:1px;
            border-top-left-radius:inherit;border-top-right-radius:inherit;
            background:linear-gradient(90deg,transparent,rgba(21,23,29,0.10),transparent);pointer-events:none;}

            section[id] {
                scroll-margin-top: 5rem;
            }

            .wrap{max-width:1240px;margin:0 auto;padding-left:clamp(20px,5vw,48px);padding-right:clamp(20px,5vw,48px);}
            .section{padding-top:clamp(72px,10vw,150px);padding-bottom:clamp(72px,10vw,150px);position:relative;}

            @media (prefers-reduced-motion: reduce) {
                .nb-header, .nb-nav__link::after, .nb-mobile { transition: none !important; }
            }
        </style>
    </body>
</html>
