---
import { Image } from 'astro:assets';
import { casesData } from '../../data/content';

// Cases — light panel: case studies with product image placeholders + metric
---

<section id="wdrozenia" class="section nb-cases nb-panel bg-paper">
  <div class="wrap">
    <div class="nb-sec-head" data-reveal>
      <span class="eyebrow">{casesData.sectionLabel}</span>
      <h2 class="h2 nb-sec-head__title">{casesData.heading}</h2>
      <p class="lead nb-sec-head__body">{casesData.subheading}</p>
    </div>

    <div class="nb-cases__list">
      {casesData.items.map((c, i) => (
        <article class={`nb-case ${i % 2 ? 'is-rev' : ''}`} data-reveal data-reveal-delay={String(i + 1)}>
          <div class="nb-case__body">
            <div class="nb-case__head">
              <span class="nb-case__num">{c.id}</span>
              <span class="nb-case__kicker caption">{c.kicker}</span>
            </div>
            <h3 class="h3 nb-case__title">{c.title}</h3>
            <p class="nb-case__desc">{c.desc}</p>
            <div class="nb-case__steps">
              {c.steps.map((s, si) => (
                <span class="nb-case__step">
                  <span class="nb-case__step-n">{String(si+1).padStart(2,"0")}</span>{s}
                </span>
              ))}
            </div>
          </div>
          <div class="nb-case__visual">
            <div class="nb-case__frame">
              <span class="nb-case__dots"><i></i><i></i><i></i></span>
              <div class="nb-case__img-wrap">
                  <Image
                      src={c.image}
                      alt={c.title}
                      class="nb-case__img"
                      widths={[440, 660, 880]}
                      sizes="(max-width: 920px) 92vw, 440px"
                      format="webp"
                      quality={72}
                      loading="lazy"
                      decoding="async"
                  />
              </div>
            </div>
            <div class="nb-case__metric">
              <span class="nb-case__metric-big">{c.metric}</span>
              <span class="nb-case__metric-label">{c.metricLabel}</span>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
/* ---------------- CASES ---------------- */
.nb-cases{background:var(--color-paper-2);}
.nb-cases__list{display:flex;flex-direction:column;gap:clamp(48px, 6vw, 96px);}
.nb-case{position:relative;display:grid;grid-template-columns:1fr minmax(320px, 440px);gap:clamp(32px, 5vw, 72px);align-items:center;outline:none;}
.nb-case.is-rev .nb-case__body{order:2;}
.nb-case.is-rev .nb-case__visual{order:1;}

.nb-case__head{display:flex;align-items:center;gap:18px;margin-bottom:18px;}
.nb-case__num{font-family:var(--font-heading);font-weight:700;font-size:clamp(40px, 4vw, 58px);color:var(--color-ink-4);line-height:1;transition:color 300ms;}
.nb-case:hover .nb-case__num{color:var(--color-brass);}
.nb-case__kicker{color:var(--color-brass);}
.nb-case__title{margin:0 0 14px;font-size:clamp(22px, 2.2vw, 30px); color: var(--color-ink);}
.nb-case__desc{font-size:15px;line-height:1.65;color:var(--color-ink-2);margin:0 0 22px;max-width:520px;}
.nb-case__steps{display:flex;flex-wrap:wrap;gap:10px;}
.nb-case__step{display:inline-flex;align-items:center;gap:8px;font-family:var(--font-mono);font-size:12px;letter-spacing:0.04em;color:var(--color-ink-3);border:1px solid rgba(21, 23, 29, 0.10);padding:7px 12px;}
.nb-case__step-n{color:var(--color-brass);font-weight:600;}

.nb-case__visual{position:relative;}
.nb-case__frame{background:#0E121C;border:1px solid var(--color-paper-edge);border-radius:10px;overflow:hidden;box-shadow: 0 2px 6px rgba(21,23,29,0.06), 0 28px 60px -24px rgba(21,23,29,0.22);transition:transform 300ms, box-shadow 300ms;}
.nb-case:hover .nb-case__frame{transform:translateY(-4px);box-shadow:0 32px 70px -28px rgba(21,23,29,0.32);}
.nb-case__dots{display:flex;gap:7px;padding:13px 16px;background:#10131c;border-bottom:1px solid rgba(255,255,255,0.05);}
.nb-case__dots i{width:9px;height:9px;border-radius:50%;background:#2a3142;}
.nb-case__dots i:first-child{background:var(--color-brass-bright);opacity:0.7;}
.nb-case__img-wrap{display:block;width:100%;height:clamp(220px, 24vw, 300px);background:var(--color-paper-3);overflow:hidden;position:relative;}
.nb-case__img{width:100%;height:100%;object-fit:cover;opacity:0.85;transition:opacity 500ms,transform 500ms;}
.nb-case:hover .nb-case__img{opacity:1;transform:scale(1.04);}
.nb-case__metric{position:absolute;bottom:-22px;left:-22px;background:var(--color-ink);border:1px solid var(--color-brass);padding:16px 22px;box-shadow: 0 2px 6px rgba(21,23,29,0.06), 0 28px 60px -24px rgba(21,23,29,0.22);z-index: 2;}
.nb-case.is-rev .nb-case__metric{left:auto;right:-22px;}
.nb-case__metric-big{display:block;font-family:var(--font-heading);font-weight:700;font-size:clamp(26px, 2.6vw, 38px);color:var(--color-brass-bright);line-height:1;white-space:nowrap;}
.nb-case__metric-label{display:block;font-family:var(--font-mono);font-size:11px;letter-spacing:0.1em;text-transform:uppercase;color:var(--color-steel);margin-top:8px;}

.nb-sec-head {
  max-width: 680px;
  margin-bottom: clamp(48px, 6vw, 76px);
}
.nb-sec-head__title {
  margin: 18px 0 0;
  font-size: clamp(30px, 3.6vw, 52px);
  font-weight: 700;
}
.nb-sec-head__body {
  margin-top: 22px;
  font-size: clamp(18px, 1.6vw, 22px);
  line-height: 1.55;
  color: var(--color-ink-2);
}

@media(max-width:860px){
  .nb-case{grid-template-columns:1fr;gap:32px;}
  .nb-case.is-rev .nb-case__body{order:1;}
  .nb-case.is-rev .nb-case__visual{order:2;}
  .nb-case__metric{left:16px;bottom:-18px;}
  .nb-case.is-rev .nb-case__metric{right:auto;left:16px;}
}
</style>
