---
import { examplesData, marqueeWords } from '../../data/content';

const row = [...marqueeWords, ...marqueeWords, ...marqueeWords];
---

<section id="examples" class="section nb-panel bg-paper">
  <div class="wrap">
    <div class="nb-sec-head">
      <span class="eyebrow">{examplesData.sectionLabel}</span>
      <h2 class="h2 nb-sec-head__title">{examplesData.heading}</h2>
      <p class="lead nb-sec-head__body">{examplesData.subheading}</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-px bg-paper-edge border border-paper-edge">
      {examplesData.items.map((item) => (
        <article class="example-card">
          <span class="nb-tag mb-4 inline-block">{item.tag}</span>
          <h3 class="h3 example-card__title">{item.title}</h3>
          <div class="example-card__arrow">→</div>
        </article>
      ))}
    </div>

    <div class="mt-16 text-center">
        <p class="font-heading text-xl mb-8">{examplesData.closing}</p>
        <a href="#brief" class="nb-btn nb-btn--primary nb-btn--lg nb-btn--corner">
            <span class="nb-corner tl"></span><span class="nb-corner tr"></span><span class="nb-corner bl"></span><span class="nb-corner br"></span>
            <span class="nb-btn__label">OPISZ SWÓJ POMYSŁ</span>
        </a>
    </div>
  </div>
</section>

<style>
/* ---------------- MARQUEE ---------------- */
.nb-marquee{background:var(--color-onyx);overflow:hidden;padding:20px 0 64px;border-top:1px solid rgba(255,255,255,0.06);position:relative;z-index:0;}
.nb-marquee__track{display:flex;width:max-content;animation:marquee 38s linear infinite;}
.nb-marquee__item{display:inline-flex;align-items:center;}
.nb-marquee__word{font-family:var(--font-heading);font-weight:600;font-size:16px;letter-spacing:0.18em;text-transform:uppercase;color:var(--color-silver-soft);}
.nb-marquee__sep{width:7px;height:7px;margin:0 34px;background:var(--color-brass-bright);transform:rotate(45deg);opacity:0.85;}
@keyframes marquee{to{transform:translateX(-33.33%);}}

/* ---------------- EXAMPLES ---------------- */
.example-card {
  background: var(--color-paper-2);
  padding: 32px;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-height: 200px;
  transition: background 300ms;
}
.example-card:hover {
  background: var(--color-paper-3);
}
.example-card__title {
  font-size: 18px;
  letter-spacing: 0.04em;
  margin: 0;
  color: var(--color-ink);
}
.example-card__arrow {
  margin-top: 24px;
  color: var(--color-brass);
  font-size: 20px;
  text-align: right;
  opacity: 0.4;
  transition: transform 300ms, opacity 300ms;
}
.example-card:hover .example-card__arrow {
  transform: translateX(4px);
  opacity: 1;
}

.nb-tag {
  font-family: var(--font-mono);
  font-size: 10px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--color-ink-3);
  border: 1px solid rgba(21, 23, 29, 0.10);
  padding: 4px 8px;
}

.nb-sec-head {
  max-width: 680px;
  margin-bottom: clamp(48px, 6vw, 76px);
}
.nb-sec-head__title {
  margin: 18px 0 0;
  font-size: clamp(30px, 3.6vw, 52px);
  font-weight: 700;
}
.nb-sec-head__body {
  margin-top: 22px;
  font-size: clamp(18px, 1.6vw, 22px);
  line-height: 1.55;
  color: var(--color-ink-2);
}

.nb-btn {
  position: relative;
  display: inline-flex;
  align-items: center;
  gap: 11px;
  font-family: var(--font-mono);
  font-weight: 600;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  cursor: pointer;
  border: 1px solid transparent;
  transition: all 300ms cubic-bezier(0.16, 1, 0.3, 1);
  white-space: nowrap;
  text-decoration: none;
}
.nb-btn--lg { font-size: 13.5px; padding: 17px 30px; }
.nb-btn--primary {
  background: var(--color-brass-bright);
  color: var(--color-void);
}
.nb-btn--primary:hover {
  background: var(--color-brass-light);
  box-shadow: 0 12px 32px -10px rgba(197, 160, 89, 0.35);
}

/* corner marks */
.nb-btn--corner .nb-corner {
  position: absolute;
  width: 6px;
  height: 6px;
  border-color: currentColor;
  opacity: 0;
  transition: opacity 300ms;
}
.nb-btn--corner.nb-btn--primary .nb-corner {
  border-color: var(--color-void);
}
.nb-corner.tl { top: 3px; left: 3px; border-top: 1px solid; border-left: 1px solid; }
.nb-corner.tr { top: 3px; right: 3px; border-top: 1px solid; border-right: 1px solid; }
.nb-corner.bl { bottom: 3px; left: 3px; border-bottom: 1px solid; border-left: 1px solid; }
.nb-corner.br { bottom: 3px; right: 3px; border-bottom: 1px solid; border-right: 1px solid; }
.nb-btn--corner:hover .nb-corner { opacity: 0.6; }
</style>
