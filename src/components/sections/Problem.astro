---
import { problemData } from '../../data/content';
---

<section id="problem" class="section nb-panel bg-paper">
  <div class="wrap">
    <div class="nb-sec-head">
      <span class="eyebrow">{problemData.sectionLabel}</span>
      <h2 class="h2 nb-sec-head__title">{problemData.heading}</h2>
      <p class="lead nb-sec-head__body">{problemData.subheading}</p>
    </div>

    <div class="problem-list">
      {problemData.pains.map((pain, idx) => (
        <article class="problem-row">
          <div class="problem-row__head">
            <span class="problem-row__num">{String(idx + 1).padStart(2, '0')}</span>
            <h3 class="h3 problem-row__title">{pain.headline}</h3>
          </div>
          <div class="problem-row__content">
            <p class="problem-row__desc">{pain.body}</p>
            <div class="problem-row__meta">
                <span class="nb-tag">{pain.costHint}</span>
            </div>
          </div>
        </article>
      ))}
    </div>

    <div class="problem-footer">
      <p class="problem-footer__txt">{problemData.closingLine}</p>
      <a href="#brief" class="nb-btn nb-btn--ghost nb-btn--lg">
        <span class="nb-btn__label">SPRAWDŹ ILE TWOJA FIRMA TRACI</span>
      </a>
    </div>
  </div>
</section>

<style>
  .problem-list {
    display: flex;
    flex-direction: column;
    gap: 48px;
    margin-bottom: 80px;
  }
  .problem-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    padding-top: 32px;
    border-top: 1px solid var(--color-paper-edge);
  }
  .problem-row__head {
    display: flex;
    gap: 24px;
    align-items: flex-start;
  }
  .problem-row__num {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 32px;
    color: var(--color-brass);
    line-height: 1;
  }
  .problem-row__title {
    font-size: 24px;
    margin: 0;
  }
  .problem-row__desc {
    font-size: 16px;
    line-height: 1.6;
    color: var(--color-ink-2);
    margin: 0 0 16px;
  }
  .problem-row__meta {
    display: flex;
  }
  .nb-tag {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-ink-3);
    border: 1px solid rgba(21, 23, 29, 0.10);
    padding: 5px 10px;
  }

  .problem-footer {
    text-align: center;
    max-width: 800px;
    margin: 0 auto;
    padding-top: 64px;
    border-top: 1px solid var(--color-paper-edge);
  }
  .problem-footer__txt {
    font-family: var(--font-heading);
    font-size: 28px;
    font-weight: 700;
    margin-bottom: 32px;
    color: var(--color-ink);
  }

  .nb-sec-head {
    max-width: 680px;
    margin-bottom: clamp(48px, 6vw, 76px);
  }
  .nb-sec-head__title {
    margin: 18px 0 0;
    font-size: clamp(30px, 3.6vw, 52px);
    font-weight: 700;
  }
  .nb-sec-head__body {
    margin-top: 22px;
    font-size: clamp(18px, 1.6vw, 22px);
    line-height: 1.55;
    color: var(--color-ink-2);
  }

  .nb-btn {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 11px;
    font-family: var(--font-mono);
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    cursor: pointer;
    border: 1px solid transparent;
    transition: all 300ms cubic-bezier(0.16, 1, 0.3, 1);
    white-space: nowrap;
    text-decoration: none;
  }
  .nb-btn--md { font-size: 12.5px; padding: 13px 22px; }
  .nb-btn--lg { font-size: 13.5px; padding: 17px 30px; }
  .nb-btn--ghost {
    background: transparent;
    color: var(--color-ink);
    border-color: rgba(21, 23, 29, 0.10);
  }
  .nb-btn--ghost:hover {
    border-color: var(--color-brass);
    color: var(--color-brass);
  }

  @media (max-width: 860px) {
    .problem-row { grid-template-columns: 1fr; gap: 16px; }
  }
</style>
