---
import { problemData } from '../../data/content';
import GeometricGrid from '../decorations/GeometricGrid.svelte';
import BrassOrnament from '../decorations/BrassOrnament.astro';
---

<section
    id="problem"
    class="relative w-full py-24 md:py-40 px-4 md:px-12 lg:px-24 bg-void z-10 border-t border-white/5 overflow-hidden"
>
    <!-- Atmosferyczna mgła mosiężna w prawym górnym rogu (subtelna sygnatura sekcji) -->
    <div
        class="absolute top-0 right-0 w-[40rem] h-[40rem] pointer-events-none -z-0"
        style="background: radial-gradient(circle at 70% 30%, rgba(197,160,89,0.06) 0%, transparent 60%);"
    ></div>

    <!-- Subtelna animowana siatka -->
    <GeometricGrid client:visible columns={16} rows={10} opacity={0.04} density={0.12} />

    <!-- Galery corner brackets jako sygnatura redakcyjna -->
    <div class="absolute top-8 left-8 hidden md:block pointer-events-none">
        <BrassOrnament variant="corner-tl" size="md" />
    </div>
    <div class="absolute bottom-8 right-8 hidden md:block pointer-events-none">
        <BrassOrnament variant="corner-br" size="md" />
    </div>

    <div class="relative max-w-7xl mx-auto">
        <!-- Header sekcji: editorial dwukolumnowy z bezpiecznym podziałem -->
        <header class="grid grid-cols-1 md:grid-cols-12 gap-8 md:gap-16 mb-16 md:mb-24 pb-8 border-b border-white/10">
            <div class="md:col-span-6 lg:col-span-7">
                <span class="block text-brass font-mono text-xs tracking-[0.3em] uppercase mb-4">
                    {problemData.sectionLabel}
                </span>
                <h2 class="font-heading font-bold text-silver tracking-[0.05em] uppercase leading-[0.95] text-[clamp(2.25rem,6vw,4.75rem)]">
                    {problemData.heading}
                </h2>
            </div>
            <p class="md:col-span-6 lg:col-span-5 text-steel font-sans text-base md:text-lg leading-relaxed self-end max-w-md md:ml-auto">
                {problemData.subheading}
            </p>
        </header>

        <!-- Lista painów: każdy jako horizontalny "wiersz redakcyjny" -->
        <ol class="problem-list">
            {problemData.pains.map((pain, idx) => (
                <li class="problem-row group relative border-t border-white/10 py-8 md:py-10 transition-colors duration-200 ease-out hover:bg-white/[0.015]">
                    <div class="grid grid-cols-12 gap-4 md:gap-8 items-baseline">
                        <!-- Numer mosiężny (column 01) -->
                        <span
                            class="col-span-2 md:col-span-1 font-mono text-brass/50 text-sm tracking-widest transition-colors duration-200 ease-out group-hover:text-brass"
                        >
                            {String(idx + 1).padStart(2, '0')}
                        </span>

                        <!-- Treść painu (col 02-08) -->
                        <div class="col-span-10 md:col-span-8 space-y-2">
                            <h3
                                class="font-heading text-silver leading-tight text-[clamp(1.25rem,2.4vw,2.125rem)] transition-colors duration-200 ease-out group-hover:text-white"
                            >
                                {pain.headline}
                            </h3>
                            <p class="text-steel font-sans text-sm md:text-base leading-relaxed max-w-2xl">
                                {pain.body}
                            </p>
                        </div>

                        <!-- Cost hint pigułka (col 09-12) -->
                        <div class="col-span-12 md:col-span-3 md:text-right">
                            <span class="inline-flex items-center gap-2 px-3 py-1.5 border border-brass/40 text-brass font-mono text-[10px] md:text-xs tracking-widest uppercase">
                                <span class="inline-block w-1 h-1 bg-brass rounded-full"></span>
                                {pain.costHint}
                            </span>
                        </div>
                    </div>
                </li>
            ))}
            <li aria-hidden="true" class="border-t border-white/10"></li>
        </ol>

        <!-- Closing line: redaktorska puenta -->
        <div class="mt-16 md:mt-24 pt-12 border-t border-brass/30">
            <p class="font-heading text-silver text-center text-[clamp(1.375rem,3vw,2.5rem)] leading-snug max-w-4xl mx-auto">
                {problemData.closingLine}
            </p>

            <!-- Mid-page pull CTA -->
            <div class="mt-10 flex justify-center">
                <a
                    href="#brief"
                    class="problem-pull-cta interactive cursor-none group inline-flex items-center gap-3 text-brass font-mono text-xs tracking-[0.3em] uppercase transition-colors duration-200 ease-out hover:text-brass-light"
                >
                    <span class="inline-block w-8 h-px bg-brass transition-all duration-200 ease-out group-hover:w-12 group-hover:bg-brass-light"></span>
                    <span>SPRAWDŹ ILE TO TWOJE FIRMĘ KOSZTUJE</span>
                    <span aria-hidden="true" class="transition-transform duration-200 ease-out group-hover:translate-x-1">→</span>
                </a>
            </div>
        </div>
    </div>
</section>

<style>
    .problem-row {
        will-change: background-color;
    }
    .problem-pull-cta:focus-visible {
        outline: 1px solid var(--color-brass, #C5A059);
        outline-offset: 6px;
    }
</style>
