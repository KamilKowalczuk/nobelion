---
import { audienceData } from '../../data/content';
---

<section id="audience" class="section nb-panel bg-paper">
  <div class="wrap">
    <div class="nb-sec-head">
      <span class="eyebrow">{audienceData.sectionLabel}</span>
      <h2 class="h2 nb-sec-head__title">{audienceData.heading}</h2>
      <p class="lead nb-sec-head__body">{audienceData.subheading}</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-px bg-paper-edge border border-paper-edge">
      {audienceData.segments.map((segment) => (
        <article class="audience-card">
          <div class="flex justify-between items-start mb-8">
            <span class="audience-card__num">{segment.number}</span>
          </div>
          <h3 class="h3 audience-card__title">{segment.name}</h3>
          <p class="audience-card__desc">{segment.typical}</p>
        </article>
      ))}
    </div>

    <div class="mt-16 text-center">
        <p class="font-heading text-xl mb-8">{audienceData.closing}</p>
        <a href="#brief" class="nb-btn nb-btn--ghost nb-btn--lg">
            <span class="nb-btn__label">WYPEŁNIJ BRIEF</span>
        </a>
    </div>
  </div>
</section>

<style>
/* ---------------- AUDIENCE ---------------- */
.audience-card {
  background: var(--color-paper-2);
  padding: 40px;
  min-height: 240px;
  transition: background 300ms;
}
.audience-card:hover {
  background: var(--color-paper-3);
}
.audience-card__num {
  font-family: var(--font-mono);
  font-size: 12px;
  color: var(--color-brass);
  letter-spacing: 0.2em;
}
.audience-card__title {
  font-size: 20px;
  margin: 0 0 16px;
  color: var(--color-ink);
}
.audience-card__desc {
  font-size: 15px;
  line-height: 1.6;
  color: var(--color-ink-3);
}

.nb-sec-head {
  max-width: 680px;
  margin-bottom: clamp(48px, 6vw, 76px);
}
.nb-sec-head__title {
  margin: 18px 0 0;
  font-size: clamp(30px, 3.6vw, 52px);
  font-weight: 700;
}
.nb-sec-head__body {
  margin-top: 22px;
  font-size: clamp(18px, 1.6vw, 22px);
  line-height: 1.55;
  color: var(--color-ink-2);
}

.nb-btn {
  position: relative;
  display: inline-flex;
  align-items: center;
  gap: 11px;
  font-family: var(--font-mono);
  font-weight: 600;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  cursor: pointer;
  border: 1px solid transparent;
  transition: all 300ms cubic-bezier(0.16, 1, 0.3, 1);
  white-space: nowrap;
  text-decoration: none;
}
.nb-btn--lg { font-size: 13.5px; padding: 17px 30px; }
.nb-btn--ghost {
  background: transparent;
  color: var(--color-ink);
  border-color: rgba(21, 23, 29, 0.10);
}
.nb-btn--ghost:hover {
  border-color: var(--color-brass);
  color: var(--color-brass);
}

.eyebrow {
  font-family: var(--font-mono);
  font-weight: 600;
  font-size: 12px;
  letter-spacing: 0.24em;
  text-transform: uppercase;
  color: var(--color-brass);
}
</style>
