---
import { servicesData } from '../../data/content';
import BrassOrnament from '../decorations/BrassOrnament.astro';
---

<section
    id="services"
    class="relative w-full py-24 md:py-40 px-4 md:px-12 lg:px-24 bg-surface z-10 border-t border-white/5 overflow-hidden"
>
    <!-- Galery corner brackets -->
    <div class="absolute top-8 right-8 hidden md:block pointer-events-none">
        <BrassOrnament variant="corner-tr" size="md" />
    </div>
    <div class="absolute bottom-8 left-8 hidden md:block pointer-events-none">
        <BrassOrnament variant="corner-bl" size="md" />
    </div>

    <div class="relative max-w-7xl mx-auto">
        <!-- Header sekcji -->
        <header class="grid grid-cols-1 md:grid-cols-12 gap-8 md:gap-12 mb-16 md:mb-24 pb-8 border-b border-white/10">
            <div class="md:col-span-7">
                <span class="block text-brass font-mono text-xs tracking-[0.3em] uppercase mb-4">
                    {servicesData.sectionLabel}
                </span>
                <h2 class="font-heading font-bold text-silver tracking-cinematic uppercase leading-[0.9] text-[clamp(2.5rem,7vw,5.5rem)]">
                    {servicesData.heading}
                </h2>
            </div>
            <p class="md:col-span-5 text-steel font-sans text-base md:text-lg leading-relaxed self-end max-w-md md:ml-auto">
                {servicesData.subheading}
            </p>
        </header>

        <!-- Trzy filary jako kolumny redakcyjne -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-white/5">
            {servicesData.pillars.map((pillar) => (
                <article class="service-pillar group relative bg-surface p-8 md:p-10 lg:p-12 transition-colors duration-200 ease-out hover:bg-void">
                    <!-- Header karty: numer + monogram tytułu w jednej linii -->
                    <div class="flex items-start justify-between mb-8 relative z-10">
                        <span
                            class="font-mono text-brass text-xs tracking-[0.3em] uppercase pt-1"
                            aria-hidden="true"
                        >
                            FILAR {pillar.id}
                        </span>
                        <span
                            class="font-heading text-brass/15 text-5xl md:text-6xl leading-none pointer-events-none select-none transition-colors duration-200 ease-out group-hover:text-brass/30"
                            aria-hidden="true"
                        >
                            {pillar.id}
                        </span>
                    </div>

                    <!-- Etykieta nazwy filaru (już bez konfliktu z numerem) -->
                    <h3 class="font-heading text-silver text-2xl md:text-3xl tracking-[0.08em] uppercase leading-tight mb-6 relative z-10 transition-colors duration-200 ease-out group-hover:text-white">
                        {pillar.name}
                    </h3>

                    <!-- Lead (jednolinijkowa obietnica) -->
                    <p class="font-heading text-brass text-lg md:text-xl leading-snug mb-6 max-w-md">
                        {pillar.lead}
                    </p>

                    <!-- Body (rozwinięcie) -->
                    <p class="font-sans text-steel text-sm md:text-base leading-relaxed mb-8 max-w-md">
                        {pillar.body}
                    </p>

                    <!-- Lista deliverables (z mosiężnym myślnikiem) -->
                    <ul class="space-y-3 mb-10">
                        {pillar.deliverables.map((item: string) => (
                            <li class="flex gap-3 text-silver/85 font-sans text-sm md:text-[15px] leading-relaxed">
                                <span class="text-brass flex-shrink-0 mt-[6px]" aria-hidden="true">
                                    <svg width="14" height="2" viewBox="0 0 14 2" fill="none">
                                        <line x1="0" y1="1" x2="14" y2="1" stroke="currentColor" stroke-width="1.5"/>
                                    </svg>
                                </span>
                                <span>{item}</span>
                            </li>
                        ))}
                    </ul>

                    <!-- Outcome jako pigułka (akcent emocjonalny) -->
                    <div class="pt-6 border-t border-white/10">
                        <p class="text-brass font-mono text-[11px] md:text-xs tracking-widest uppercase mb-2">
                            EFEKT
                        </p>
                        <p class="font-heading text-silver text-base md:text-lg leading-snug">
                            {pillar.outcome}
                        </p>
                    </div>
                </article>
            ))}
        </div>
    </div>
</section>

<style>
    .service-pillar {
        will-change: background-color;
    }
</style>
