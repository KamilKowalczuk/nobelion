---
import { servicesData, capabilitiesData } from '../../data/content';

// Services — light section: intro + 3 main offer cards + 6 capability bento + showcase
---

<section id="oferta" class="section nb-services nb-panel">
  <div class="wrap">

    <!-- ── Section Head ── -->
    <div class="nb-sec-head" data-reveal>
      <span class="eyebrow">{servicesData.sectionLabel}</span>
      <h2 class="h2 nb-sec-head__title">{servicesData.heading}</h2>
      <p class="lead nb-sec-head__body">{servicesData.subheading}</p>
    </div>

    <!-- ── 3 Offer Cards ── -->
    <div class="nb-offer">
      {servicesData.pillars.map((s, i) => (
        <article class="nb-offer__card" data-reveal style={`--reveal-delay:${i * 120}ms`}>
          <span class="nb-offer__num caption">{s.id}</span>

          <div class="nb-offer__icon">
            {/* app — window with inner panel */}
            {i === 0 && (
              <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="3" width="18" height="18" rx="2"/>
                <path d="M3 9h18"/>
                <rect x="6" y="12" width="5" height="6" rx="0.5"/>
              </svg>
            )}
            {/* workflow — connected nodes */}
            {i === 1 && (
              <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="3" width="5" height="5" rx="1"/>
                <rect x="16" y="3" width="5" height="5" rx="1"/>
                <rect x="16" y="16" width="5" height="5" rx="1"/>
                <path d="M5.5 8v5a3 3 0 003 3H16M18.5 8v8"/>
              </svg>
            )}
            {/* bot — robot head */}
            {i === 2 && (
              <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="4" y="8" width="16" height="11" rx="2"/>
                <path d="M12 4v4"/>
                <circle cx="12" cy="3" r="1"/>
                <circle cx="9" cy="13.5" r="1"/>
                <circle cx="15" cy="13.5" r="1"/>
                <path d="M2 12v3M22 12v3"/>
              </svg>
            )}
          </div>

          <h3 class="h3 nb-offer__title">{s.name}</h3>
          <p class="nb-offer__desc">{s.lead} {s.body}</p>

          <div class="nb-offer__tags">
            {s.deliverables.map((t) => <span class="nb-tag">{t}</span>)}
          </div>
        </article>
      ))}
    </div>

    <!-- ── 6 Capabilities Grid ── -->
    <div class="nb-cap">
      {capabilitiesData.map((c, i) => (
        <div class="nb-cap__item" data-reveal style={`--reveal-delay:${i * 80}ms`}>
          <div class="nb-cap__icon">
            {c.icon === 'lightning' && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M13 2L4 14h7l-1 8 9-12h-7l1-8z"/>
              </svg>
            )}
            {c.icon === 'workflow' && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="3" width="5" height="5" rx="1"/>
                <rect x="16" y="16" width="5" height="5" rx="1"/>
                <rect x="16" y="3" width="5" height="5" rx="1"/>
                <path d="M5.5 8v5a3 3 0 003 3H16M18.5 8v8"/>
              </svg>
            )}
            {c.icon === 'diamond' && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M6 3h12l4 6-10 13L2 9z"/>
                <path d="M2 9h20M9 3l-3 6 6 13M15 3l3 6-6 13"/>
              </svg>
            )}
            {c.icon === 'shield' && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 2l8 3v6c0 5-3.5 8.5-8 11-4.5-2.5-8-6-8-11V5z"/>
                <path d="M8.5 11.5L11 14l4.5-5"/>
              </svg>
            )}
            {c.icon === 'server' && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="4" width="18" height="7" rx="1"/>
                <rect x="3" y="13" width="18" height="7" rx="1"/>
                <circle cx="7" cy="7.5" r="0.5"/>
                <circle cx="7" cy="16.5" r="0.5"/>
              </svg>
            )}
            {c.icon === 'user' && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="8" r="4"/>
                <path d="M4 21c0-4.5 3.5-7 8-7s8 2.5 8 7"/>
              </svg>
            )}
          </div>
          <div>
            <h4 class="nb-cap__title">{c.title}</h4>
            <p class="nb-cap__desc">{c.desc}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- ── Showcase Browser Frame ── -->
    <div class="nb-showcase" data-reveal>
      <div class="nb-showcase__label">
        <span class="eyebrow">Przykład realizacji</span>
        <p class="nb-showcase__cap">Tak wygląda gotowy system, który dostajesz — aplikacja, panel lub dashboard skrojony pod Twój proces.</p>
      </div>

      <div class="nb-showcase__frame">
        <div class="nb-showcase__bar">
          <span class="nb-showcase__dots"><i></i><i></i><i></i></span>
          <span class="nb-showcase__skeleton"><b></b></span>
        </div>
        <img class="nb-showcase__img" src="/example_of_system.png" alt="Dedykowany system operacyjny dla firmy" loading="lazy" />
      </div>
    </div>

  </div>
</section>

<style>
/* ═══════════════════ SERVICES SECTION ═══════════════════ */
.nb-services { background: var(--color-paper); }

/* ── Section Head ── */
.nb-sec-head { max-width: 680px; margin-bottom: clamp(48px, 6vw, 76px); }
.nb-sec-head--center { margin-left: auto; margin-right: auto; text-align: center; }
.nb-sec-head__title { margin: 18px 0 0; }
.nb-sec-head__body { margin-top: 22px; }

/* ── Offer Cards ── */
.nb-offer {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
  margin-bottom: 28px;
}
.nb-offer__card {
  position: relative;
  background: var(--color-paper-2);
  border: 1px solid var(--color-paper-edge);
  padding: 38px 32px 32px;
  overflow: hidden;
  transition: border-color 300ms, box-shadow 300ms, transform 300ms;
}
.nb-offer__card:hover {
  border-color: var(--color-brass);
  box-shadow: var(--shadow-lift);
  transform: translateY(-4px);
}
.nb-offer__num {
  position: absolute;
  top: 20px;
  right: 24px;
  color: var(--color-ink-4);
}
.nb-offer__icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 60px;
  height: 60px;
  border: 1px solid var(--color-paper-edge);
  color: var(--color-brass);
  margin-bottom: 26px;
  transition: border-color 300ms, background 300ms;
}
.nb-offer__card:hover .nb-offer__icon {
  border-color: var(--color-brass);
  background: rgba(184, 137, 62, 0.06);
}
.nb-offer__title { margin: 0 0 14px; font-size: clamp(18px, 1.5vw, 21px); }
.nb-offer__desc {
  font-size: 15px;
  line-height: 1.65;
  color: var(--color-ink-2);
  margin: 0 0 22px;
}
.nb-offer__tags { display: flex; flex-wrap: wrap; gap: 8px; }
.nb-tag {
  font-family: var(--font-mono);
  font-size: 11px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--color-ink-3);
  border: 1px solid var(--color-hair-ink);
  padding: 5px 10px;
}

/* ── Capabilities Grid ── */
.nb-cap {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1px;
  background: var(--color-paper-edge);
  border: 1px solid var(--color-paper-edge);
  margin-top: 32px;
}
.nb-cap__item {
  display: flex;
  gap: 16px;
  background: var(--color-paper);
  padding: 30px 28px;
  transition: background 300ms;
}
.nb-cap__item:hover { background: var(--color-paper-2); }
.nb-cap__icon {
  flex-shrink: 0;
  color: var(--color-brass);
  width: 40px;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1px solid var(--color-hair-ink);
}
.nb-cap__title {
  font-family: var(--font-heading);
  font-weight: 600;
  font-size: 15px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--color-ink);
  margin: 6px 0 8px;
}
.nb-cap__desc {
  font-size: 14px;
  line-height: 1.6;
  color: var(--color-ink-3);
  margin: 0;
}

/* ── Showcase Browser Frame ── */
.nb-showcase { margin-top: clamp(48px, 6vw, 80px); }
.nb-showcase__label {
  max-width: 620px;
  margin: 0 auto clamp(24px, 3vw, 36px);
  text-align: center;
}
.nb-showcase__cap {
  font-size: 15px;
  line-height: 1.6;
  color: var(--color-ink-3);
  margin: 14px 0 0;
}
.nb-showcase__frame {
  border: 1px solid var(--color-paper-edge);
  border-radius: 12px;
  overflow: hidden;
  box-shadow: var(--shadow-lift);
  background: #0E121C;
}
.nb-showcase__bar {
  display: flex;
  align-items: center;
  gap: 14px;
  padding: 14px 18px;
  background: #10131c;
  border-bottom: 1px solid rgba(255, 255, 255, 0.05);
}
.nb-showcase__dots { display: flex; gap: 8px; }
.nb-showcase__dots i {
  width: 11px;
  height: 11px;
  border-radius: 50%;
  background: #2a3142;
}
.nb-showcase__dots i:first-child {
  background: var(--color-brass-bright);
  opacity: 0.7;
}
.nb-showcase__skeleton {
  flex: 1;
  max-width: 360px;
  height: 20px;
  background: rgba(255, 255, 255, 0.04);
  border-radius: 999px;
  display: flex;
  align-items: center;
  padding: 0 12px;
}
.nb-showcase__skeleton b {
  display: block;
  width: 42%;
  height: 5px;
  border-radius: 3px;
  background: rgba(255, 255, 255, 0.10);
}
.nb-showcase__img {
  display: block;
  width: 100%;
  height: clamp(300px, 30vw, 460px);
  object-fit: cover;
  object-position: top center;
}

/* ── Responsive ── */
@media (max-width: 880px) {
  .nb-offer { grid-template-columns: 1fr; }
  .nb-cap { grid-template-columns: 1fr; }
}
</style>
