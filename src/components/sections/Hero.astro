---
import { heroData } from '../../data/content';

// Hero — dark onyx anchor (Split editorial variant).
// Refactored to Tailwind CSS
---

<section id="hero" class="relative min-h-dvh flex items-center overflow-hidden pt-[clamp(76px,10dvh,110px)] pb-[clamp(72px,11dvh,120px)] bg-onyx text-silver max-h-[860px]:pt-[clamp(52px,7dvh,84px)] max-h-[860px]:pb-[clamp(40px,6dvh,70px)] max-h-[760px]:pt-[clamp(42px,5.5dvh,66px)] max-h-[760px]:pb-[clamp(22px,3.8dvh,42px)] max-[920px]:h-auto max-[920px]:min-h-dvh max-[920px]:pt-[140px] max-[920px]:pb-[120px] max-[920px]:max-h-[760px]:pt-[76px] max-[920px]:max-h-[760px]:pb-[30px]">
  <div class="absolute inset-0 z-0" aria-hidden="true">
    <div class="absolute -top-[20%] left-1/2 -translate-x-1/2 w-[min(1100px,120vw)] h-[900px] blur-[8px]" style="background: radial-gradient(ellipse at center, rgba(197, 160, 89, 0.16), rgba(197, 160, 89, 0.04) 38%, transparent 64%);"></div>
    <div class="absolute inset-0 opacity-50 bg-[size:64px_64px]" style="background-image: linear-gradient(rgba(255, 255, 255, 0.025) 1px, transparent 1px), linear-gradient(90deg, rgba(255, 255, 255, 0.025) 1px, transparent 1px); mask-image: radial-gradient(ellipse 80% 70% at 50% 40%, #000 30%, transparent 75%); -webkit-mask-image: radial-gradient(ellipse 80% 70% at 50% 40%, #000 30%, transparent 75%);"></div>
  </div>

  <div class="relative z-10 w-full wrap grid grid-cols-[1.25fr_0.85fr] gap-[64px] items-center max-h-[860px]:gap-[clamp(28px,4dvh,48px)] max-[920px]:grid-cols-1 max-[920px]:gap-[48px]">
    <!-- LEFT COL -->
    <div class="max-[920px]:text-center max-[920px]:flex max-[920px]:flex-col max-[920px]:items-center">
      <div class="inline-flex items-center gap-[10px] mb-[28px] max-h-[860px]:mb-[18px]">
        <span class="w-[7px] h-[7px] bg-brass-bright rounded-full shadow-[0_0_12px_1px_var(--color-brass-glow)] animate-[hero-pulse_2.6s_cubic-bezier(0.65,0,0.35,1)_infinite] motion-reduce:animate-none"></span>
        <span class="font-mono font-semibold text-[12px] tracking-[0.24em] uppercase text-brass-bright">{heroData.microTagline}</span>
      </div>

      <h1 id="hero-title" class="font-heading font-bold uppercase leading-[1.0] tracking-[0.02em] text-silver m-0 text-[clamp(38px,6.2vw,86px)] max-h-[860px]:text-[clamp(34px,5.6vw,70px)] max-h-[760px]:text-[clamp(30px,5.2vw,58px)] [&.lit_.w]:translate-y-0 [&.lit_.ln:nth-child(2)_.w]:delay-100 [&.lit_.ln:nth-child(3)_.w]:delay-200">
        <span class="block overflow-hidden pt-[0.18em] -mt-[0.18em] ln"><span class="block translate-y-[110%] transition-transform duration-[900ms] ease-[cubic-bezier(0.83,0,0.17,1)] motion-reduce:translate-y-0 motion-reduce:transition-none w">{heroData.line1}</span></span>
        <span class="block overflow-hidden pt-[0.18em] -mt-[0.18em] ln"><span class="block translate-y-[110%] transition-transform duration-[900ms] ease-[cubic-bezier(0.83,0,0.17,1)] motion-reduce:translate-y-0 motion-reduce:transition-none w">{heroData.line2}</span></span>
        <span class="block overflow-hidden pt-[0.18em] -mt-[0.18em] ln"><span class="block translate-y-[110%] transition-transform duration-[900ms] ease-[cubic-bezier(0.83,0,0.17,1)] motion-reduce:translate-y-0 motion-reduce:transition-none w text-brass-bright">{heroData.line3}</span></span>
      </h1>

      <p class="max-w-[560px] mx-0 mt-[30px] mb-[38px] text-[clamp(16px,1.5vw,19px)] leading-[1.6] text-silver-soft opacity-0 animate-[hero-fade_0.9s_cubic-bezier(0.16,1,0.3,1)_0.55s_forwards] motion-reduce:animate-none motion-reduce:opacity-100 max-h-[860px]:my-[18px] max-h-[860px]:text-[clamp(15px,1.28vw,18px)] max-h-[860px]:leading-[1.45] max-h-[760px]:my-[12px] max-h-[760px]:text-[clamp(14px,1.18vw,16px)] max-h-[760px]:leading-[1.38]">{heroData.subheading}</p>

      <div class="flex flex-wrap gap-[16px] opacity-0 animate-[hero-fade_0.9s_cubic-bezier(0.16,1,0.3,1)_0.7s_forwards] motion-reduce:animate-none motion-reduce:opacity-100 max-h-[860px]:gap-[12px] max-[920px]:justify-center">
        <a href={heroData.primaryCta.href} class="nb-btn nb-btn--primary nb-btn--lg group">
          <span class="nb-btn__label">{heroData.primaryCta.label}</span>
          <span class="inline-flex transition-transform duration-300 ease-[cubic-bezier(0.16,1,0.3,1)] group-hover:translate-x-1">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="square" stroke-linejoin="miter">
              <path d="M5 12 H19 M13 6 L19 12 L13 18" />
            </svg>
          </span>
        </a>
        <a href={heroData.secondaryCta.href} class="nb-btn nb-btn--ghost-light nb-btn--lg">
          <span class="nb-btn__label">{heroData.secondaryCta.label}</span>
        </a>
      </div>
    </div>

    <!-- RIGHT COL -->
    <div class="flex flex-col items-start max-[920px]:items-center">
      <div class="relative w-[min(340px,80%)] aspect-square mx-auto max-h-[860px]:w-[min(270px,70%)] max-h-[760px]:w-[min(220px,60%)] max-[920px]:w-[min(240px,60%)] max-[480px]:w-[180px]">
        <img src="/logo-icon.svg" alt="Nobelion — logo" width="340" height="340" fetchpriority="high" decoding="async" class="w-full h-full object-contain drop-shadow-[0_0_60px_rgba(197,160,89,0.22)] animate-[hero-float_7s_cubic-bezier(0.65,0,0.35,1)_infinite]" />
        <div class="absolute -inset-[6%] max-h-[760px]:-inset-[4%] border border-white/5 rounded-full animate-[hero-spin_60s_linear_infinite] before:content-[''] before:absolute before:-top-[3px] before:left-1/2 before:w-[5px] before:h-[5px] before:bg-brass-bright before:rounded-full before:shadow-[0_0_10px_var(--color-brass-glow)]"></div>
      </div>

      <div class="flex flex-col gap-[22px] mt-[36px] opacity-0 animate-[hero-fade_0.9s_cubic-bezier(0.16,1,0.3,1)_0.85s_forwards] motion-reduce:animate-none motion-reduce:opacity-100 max-h-[860px]:gap-[12px] max-h-[860px]:mt-[16px] max-h-[760px]:gap-[8px] max-h-[760px]:mt-[12px] max-[920px]:flex-row max-[920px]:flex-wrap max-[920px]:justify-center max-[920px]:gap-[24px] max-[920px]:mt-[24px]">
        {heroData.stripe.map((s) => (
          <div class="border-l-2 border-brass-bright pl-[16px] max-[920px]:border-l-0 max-[920px]:border-t-2 max-[920px]:pl-0 max-[920px]:pt-[10px] max-[920px]:text-center">
            <div class="font-heading font-bold text-[clamp(20px,2vw,27px)] text-brass-bright tracking-[0.01em] max-h-[860px]:text-[clamp(18px,1.8vw,24px)]">{s.k}</div>
            <div class="font-mono text-[11px] tracking-[0.14em] uppercase text-steel mt-[6px] max-h-[860px]:text-[10px] max-h-[860px]:mt-[4px]">{s.v}</div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <a class="absolute bottom-[28px] left-1/2 -translate-x-1/2 z-10 flex flex-col items-center gap-[10px] text-steel no-underline" href="#oferta" aria-label="Przewiń">
    <span class="font-mono text-[11px] tracking-[0.24em] uppercase text-steel">{heroData.scrollText}</span>
    <span class="relative w-[1px] h-[44px] bg-[linear-gradient(var(--color-brass-bright),transparent)] overflow-hidden after:content-[''] after:absolute after:-top-1/2 after:left-0 after:w-full after:h-1/2 after:bg-brass-bright after:animate-[scroll-cue_2s_cubic-bezier(0.65,0,0.35,1)_infinite]"></span>
  </a>
</section>

<!-- word-reveal: add .lit after 80 ms so the CSS transition fires -->
<script>
  requestAnimationFrame(() => {
    setTimeout(() => {
      document.getElementById('hero-title')?.classList.add('lit');
    }, 80);
  });
</script>

<style>
@keyframes hero-pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.35; }
}
@keyframes hero-fade {
  to { opacity: 1; }
}
@keyframes hero-float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-12px); }
}
@keyframes hero-spin {
  to { transform: rotate(360deg); }
}
@keyframes scroll-cue {
  0% { top: -50%; }
  100% { top: 100%; }
}
</style>
