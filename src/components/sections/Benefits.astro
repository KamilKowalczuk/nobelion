---
import { benefitsData, statsData } from '../../data/content';
import CountUp from '../ui/CountUp.svelte';
import BrassOrnament from '../decorations/BrassOrnament.astro';
---

<section
    id="benefits"
    class="relative w-full bg-void z-10 border-t border-white/5"
>
    <!-- PODSEKCJA A: BEFORE / AFTER COMPARISON -->
    <div class="relative w-full py-24 md:py-40 px-4 md:px-12 lg:px-24 overflow-hidden">
        <!-- Galery corner brackets -->
        <div class="absolute top-8 right-8 hidden md:block pointer-events-none">
            <BrassOrnament variant="corner-tr" size="md" />
        </div>
        <div class="absolute bottom-8 left-8 hidden md:block pointer-events-none">
            <BrassOrnament variant="corner-bl" size="md" />
        </div>

        <div class="relative max-w-7xl mx-auto">
            <header class="mb-16 md:mb-24 pb-8 border-b border-white/10">
                <span class="block text-brass font-mono text-xs tracking-[0.3em] uppercase mb-6">
                    {benefitsData.sectionLabel}
                </span>
                <h2 class="font-heading font-bold uppercase leading-[0.9] text-[clamp(2.5rem,7vw,5.5rem)] mb-6">
                    <span class="text-steel/40 line-through decoration-[0.5px] decoration-steel/40">BEZ SYSTEMU.</span>
                    <span class="text-silver"> Z SYSTEMEM.</span>
                </h2>
                <p class="font-sans text-steel text-base md:text-lg leading-relaxed max-w-2xl">
                    {benefitsData.subheading}
                </p>
            </header>

            <!-- Header rzędu: nazwy kolumn (BEZ vs Z systemem) -->
            <div class="hidden md:grid grid-cols-12 gap-4 md:gap-8 px-2 md:px-6 pb-4 border-b border-brass/30">
                <div class="md:col-span-3"></div>
                <div class="md:col-span-5">
                    <span class="font-mono text-steel/60 text-[10px] md:text-xs tracking-[0.3em] uppercase">
                        BEZ SYSTEMU
                    </span>
                </div>
                <div class="md:col-span-4">
                    <span class="font-mono text-brass text-[10px] md:text-xs tracking-[0.3em] uppercase">
                        Z SYSTEMEM
                    </span>
                </div>
            </div>

            <!-- 4 wiersze before/after -->
            <div class="space-y-px bg-white/5">
                {benefitsData.items.map((item) => (
                    <div class="benefit-row group grid grid-cols-1 md:grid-cols-12 gap-4 md:gap-8 bg-void py-10 md:py-12 px-2 md:px-6 transition-colors duration-200 ease-out hover:bg-surface/40 items-baseline">
                        <!-- Title (col 01-03) -->
                        <h3 class="md:col-span-3 font-heading text-brass text-2xl md:text-3xl uppercase tracking-[0.08em]">
                            {item.title}
                        </h3>

                        <!-- Before (col 04-07) -->
                        <div class="md:col-span-5">
                            <span class="md:hidden block font-mono text-steel/60 text-[10px] tracking-[0.3em] uppercase mb-1">BEZ SYSTEMU</span>
                            <p class="font-sans text-steel text-sm md:text-base leading-relaxed line-through decoration-1 decoration-steel/40">
                                {item.before}
                            </p>
                        </div>

                        <!-- After (col 08-12) -->
                        <div class="md:col-span-4">
                            <span class="md:hidden block font-mono text-brass text-[10px] tracking-[0.3em] uppercase mb-1">Z SYSTEMEM</span>
                            <p class="font-heading text-silver text-base md:text-lg leading-snug flex gap-3">
                                <span class="text-brass flex-shrink-0" aria-hidden="true">•</span>
                                <span>{item.after}</span>
                            </p>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </div>

    <!-- PODSEKCJA B: STATS (3 wielkie liczby na bg-surface) -->
    <div class="relative w-full bg-surface border-y border-white/10">
        <!-- Subtelny wzór tła -->
        <div
            class="absolute inset-0 opacity-5 pointer-events-none"
            style="background-image: radial-gradient(#C5A059 1px, transparent 1px); background-size: 40px 40px;"
        ></div>

        <div class="relative max-w-7xl mx-auto px-6 md:px-12 py-20 md:py-28">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-0 divide-y md:divide-y-0 md:divide-x divide-white/10">
                {statsData.map((stat) => (
                    <div class="px-4 py-8 md:py-0 md:px-8">
                        <CountUp
                            client:visible
                            value={stat.value}
                            label={stat.label}
                            prefix={stat.prefix}
                            suffix={stat.suffix}
                        />
                    </div>
                ))}
            </div>

            <p class="mt-12 md:mt-16 text-center font-mono text-steel/60 text-xs tracking-widest uppercase">
                Te liczby są realne. Pochodzą z naszych wdrożeń z ostatnich 12 miesięcy.
            </p>
        </div>
    </div>
</section>

<style>
    .benefit-row { will-change: background-color; }
</style>
