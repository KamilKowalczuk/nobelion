---
import { statsData } from '../../data/content';
import CountUp from '../ui/CountUp.svelte';

// Proof — DARK onyx anchor with spring count-up stats
---

<section id="benefits" class="onyx nb-proof nb-panel nb-panel--dark">
  <div class="wrap nb-proof__inner">
    <div class="nb-proof__head" data-reveal>
      <span class="eyebrow">Dowody</span>
      <h2 class="h2">Wynik, nie obietnice</h2>
    </div>

    <div class="nb-proof__grid" id="proof-grid">
      {statsData.map((s) => (
        <div class="nb-stat">
          <div class="nb-stat__num">
            {s.pre && <span class="nb-stat__aff">{s.pre}</span>}
            <span class="nb-stat__big">
              <CountUp
                value={Number(s.value)}
                label=""
                prefix=""
                suffix=""
                client:visible
              />
            </span>
            <span class="nb-stat__aff">{s.suffix}</span>
          </div>
          <div class="nb-stat__label">
            {s.label.split('\n').map((l) => <span>{l}</span>)}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
/* ---------------- PROOF (dark curtain) ---------------- */
.nb-proof {
  position: relative;
  background-color: var(--color-onyx);
  color: var(--color-silver);
}
.nb-proof__inner {
  padding-top: clamp(80px, 9vw, 130px);
  padding-bottom: clamp(80px, 9vw, 130px);
  position: relative;
}
.nb-proof__inner::after {
  content: "";
  position: absolute;
  width: 520px;
  height: 520px;
  border-radius: 50%;
  pointer-events: none;
  background: radial-gradient(circle, rgba(197, 160, 89, 0.10), transparent 62%);
  top: -120px;
  right: -120px;
}

.nb-proof__head {
  margin-bottom: 60px;
}
.nb-proof__head .h2 {
  margin-top: 14px;
  font-size: clamp(30px, 3.6vw, 52px);
  font-weight: 700;
  color: var(--color-silver);
}

.nb-proof__grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1px;
  background: var(--color-hair-light);
  border-top: 1px solid var(--color-hair-light);
  border-bottom: 1px solid var(--color-hair-light);
}

.nb-stat {
  background: var(--color-onyx);
  padding: 48px 36px;
}
.nb-stat__num {
  display: flex;
  align-items: baseline;
  gap: 4px;
  font-family: var(--font-heading);
  font-weight: 700;
  color: var(--color-silver);
}
.nb-stat__big {
  font-size: clamp(56px, 7vw, 92px);
  line-height: 1;
  letter-spacing: -0.01em;
  font-variant-numeric: tabular-nums;
}
.nb-stat__aff {
  font-size: clamp(22px, 2.4vw, 32px);
  color: var(--color-brass-bright);
  font-weight: 600;
}
.nb-stat__label {
  display: flex;
  flex-direction: column;
  font-family: var(--font-mono);
  font-size: 12px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--color-steel);
  margin-top: 20px;
  line-height: 1.7;
}

.eyebrow {
  font-family: var(--font-mono);
  font-weight: 600;
  font-size: 12px;
  letter-spacing: 0.24em;
  text-transform: uppercase;
  color: var(--color-brass-bright);
}

@media (max-width: 760px) {
  .nb-proof__grid {
    grid-template-columns: 1fr;
  }
}
</style>
