---
import { faqData } from '../../data/content';
import FaqList from '../ui/FaqList.svelte';
---

<section id="faq" class="section nb-faq nb-panel bg-paper">
  <div class="wrap nb-faq__inner">
    <div class="nb-faq__aside" data-reveal>
      <span class="eyebrow">FAQ</span>
      <h2 class="h2 nb-faq__title">Pytania, które padają najczęściej</h2>
      <p class="nb-faq__note">Czegoś brakuje? Napisz wprost w briefie — odpowiemy konkretnie.</p>
    </div>
    <div class="nb-faq__list" data-reveal data-reveal-delay="1">
      <FaqList client:visible data={faqData} />
    </div>
  </div>
</section>

<style>
/* ---------------- FAQ ---------------- */
.nb-faq{background:var(--color-paper);}
.nb-faq__inner{display:grid;grid-template-columns:0.85fr 1.15fr;gap:64px;align-items:start;}
.nb-faq__title{margin:18px 0 18px; font-size: clamp(30px, 3.6vw, 52px); font-weight: 700; color: var(--color-ink);}
.nb-faq__note{font-size:14px;color:var(--color-ink-3);}
.nb-faq__list{border-top:1px solid rgba(21, 23, 29, 0.10);}



@media(max-width:820px){.nb-faq__inner{grid-template-columns:1fr;gap:36px;}}
</style>
