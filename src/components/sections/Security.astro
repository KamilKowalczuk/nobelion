---
import { securityData } from '../../data/content';

const iconMap: Record<string, string> = {
    lock:    '<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.15"><rect x="3" y="11" width="18" height="11" rx="1"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/><circle cx="12" cy="16.5" r="1.5"/></svg>',
    shield:  '<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.15"><path d="M12 2l8 4v5c0 5.25-3.5 10-8 11.5C7.5 21 4 16.25 4 11V6l8-4z"/></svg>',
    diamond: '<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.15"><path d="M12 2L2 9l10 13L22 9 12 2z"/><path d="M2 9h20"/><path d="M7.5 2L5 9l7 13"/><path d="M16.5 2L19 9l-7 13"/></svg>',
    server:  '<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.15"><rect x="2" y="2" width="20" height="8" rx="1"/><rect x="2" y="14" width="20" height="8" rx="1"/><circle cx="6" cy="6" r="1"/><circle cx="6" cy="18" r="1"/><path d="M10 6h6"/><path d="M10 18h6"/></svg>'
};
---

<section id="bezpieczenstwo" class="onyx nb-security nb-panel nb-panel--dark">
    <div class="wrap nb-security__inner">
        <div class="nb-security__head" data-reveal>
            <span class="eyebrow">{securityData.sectionLabel}</span>
            <h2 class="h2" style="margin-top:14px;">{securityData.heading}</h2>
            <p class="lead nb-security__body">{securityData.subheading}</p>
        </div>

        <div class="nb-security__grid">
            {securityData.items.map((item, i) => (
                <div class="nb-sec-card" data-reveal data-reveal-delay={String(i + 1)}>
                    <span class="nb-sec-card__icon" set:html={iconMap[item.icon] || iconMap.shield} />
                    <h3 class="nb-sec-card__title h4">{item.title}</h3>
                    <p class="nb-sec-card__desc">{item.desc}</p>
                </div>
            ))}
        </div>
    </div>
</section>

<style>
    .nb-security{position:relative;}
    .nb-security__inner{padding-top:clamp(80px,9vw,130px);padding-bottom:clamp(80px,9vw,130px);position:relative;}
    .nb-security__inner::before{content:"";position:absolute;width:520px;height:520px;border-radius:50%;pointer-events:none;
      background:radial-gradient(circle,rgba(197,160,89,0.10),transparent 62%);bottom:-160px;left:-120px;}
    .nb-security__head{max-width:640px;margin-bottom:56px;}
    .nb-security__body{margin-top:20px;color:var(--color-silver-soft);}
    .nb-security__grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:var(--color-hair-light);border:1px solid var(--color-hair-light);}
    .nb-sec-card{background:var(--color-onyx);padding:36px 28px;transition:background 300ms;}
    .nb-sec-card:hover{background:var(--color-surface);}
    .nb-sec-card__icon{display:inline-flex;width:50px;height:50px;align-items:center;justify-content:center;border:1px solid var(--color-hair-light);color:var(--color-brass-bright);margin-bottom:22px;}
    .nb-sec-card__title{margin:0 0 12px;color:var(--color-silver);}
    .nb-sec-card__desc{font-size:14px;line-height:1.62;color:var(--color-steel);margin:0;}
    @media(max-width:880px){.nb-security__grid{grid-template-columns:1fr 1fr;}}
    @media(max-width:520px){.nb-security__grid{grid-template-columns:1fr;}}
</style>
