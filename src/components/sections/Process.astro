---
import { processData } from '../../data/content';

// Process — light alt section: 4-step timeline with checkpoints
---

<section id="proces" class="section nb-process nb-panel bg-paper-3">
  <div class="wrap">
    <div class="nb-sec-head" data-reveal>
      <span class="eyebrow">{processData.sectionLabel}</span>
      <h2 class="h2 nb-sec-head__title">{processData.heading}</h2>
      <p class="lead nb-sec-head__body">{processData.subheading}</p>
    </div>
    <div class="nb-steps">
      <div class="nb-steps__rail" aria-hidden="true"></div>
      {processData.steps.map((p, i) => (
        <div class="nb-step" data-reveal data-reveal-delay={String(i + 1)}>
          <div class="nb-step__node"><span></span></div>
          <div class="nb-step__head">
            <span class="nb-step__n">{p.n}</span>
            <span class="nb-step__time mono">{p.time}</span>
          </div>
          <h3 class="nb-step__title h4">{p.title}</h3>
          <p class="nb-step__desc">{p.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
/* ---------------- PROCESS ---------------- */
.nb-process{background:var(--color-paper-3);}
.nb-steps{position:relative;display:grid;grid-template-columns:repeat(4,1fr);gap:28px;}
.nb-steps__rail{position:absolute;top:7px;left:0;right:0;height:1px;background:rgba(21, 23, 29, 0.10);}
.nb-step{position:relative;padding-top:34px;}
.nb-step__node{position:absolute;top:0;left:0;width:15px;height:15px;border:1px solid var(--color-brass);background:var(--color-paper-3);display:flex;align-items:center;justify-content:center;transform:rotate(45deg);}
.nb-step__node span{width:5px;height:5px;background:var(--color-brass);}
.nb-step__head{display:flex;align-items:baseline;gap:12px;margin-bottom:14px;}
.nb-step__n{font-family:var(--font-heading);font-weight:700;font-size:26px;color:var(--color-brass); line-height: 1;}
.nb-step__time{font-family: var(--font-mono); font-size:11px;letter-spacing:0.1em;text-transform:uppercase;color:var(--color-ink-3);}
.nb-step__title{margin:0 0 10px; font-family: var(--font-heading); font-weight: 600; font-size: 19px; color: var(--color-ink);}
.nb-step__desc{font-size:14px;line-height:1.62;color:var(--color-ink-2);margin:0;}


@media(max-width:880px){.nb-steps{grid-template-columns:1fr 1fr;gap:36px 28px;}.nb-steps__rail{display:none;}}
@media(max-width:520px){.nb-steps{grid-template-columns:1fr;}}
</style>
