---
import { contactData } from '../../data/content';
import BriefFlow from '../core/BriefFlow.svelte';
import { getApiUrl, API_ENDPOINTS } from '../../lib/constants';
import { renderMarkdown } from '../../lib/markdown';

const apiUrl = getApiUrl();
let legalDocs: Record<string, { title: string; html: string; version?: string }> = {};

try {
  const res = await fetch(`${apiUrl}${API_ENDPOINTS.publicDocuments()}`);
  if (res.ok) {
    const data = await res.json();
    for (const d of (data.documents || [])) {
      legalDocs[d.docType] = { title: d.title, html: renderMarkdown(d.content), version: d.version };
    }
  }
} catch { /* ignored */ }
---

<section id="brief" class="section nb-brief nb-panel bg-paper-3">
  <div class="wrap">
    <div class="nb-sec-head nb-sec-head--center" data-reveal>
      <span class="eyebrow">{contactData.eyebrow}</span>
      <h2 class="h2 nb-sec-head__title">{contactData.heading}</h2>
      <p class="lead nb-sec-head__body">{contactData.body}</p>
    </div>

    <div class="nb-brief__flow-container">
        <BriefFlow client:visible={{ rootMargin: '600px' }} {legalDocs} />
    </div>
  </div>
</section>

<style>
/* ---------------- BRIEF ---------------- */
.nb-brief{background:var(--color-paper-3);position:relative;}



.nb-brief__flow-container {
    max-width: 1080px;
    margin: 0 auto;
}
</style>
