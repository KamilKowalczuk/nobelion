---
// ClosingPage — wspólna scena domknięcia (potwierdzenie płatności / przerwana
// płatność). Pełny styl Onyx: tło jak hero, medalion z pierścieniem, Cinzel.
interface Step {
    n: string;
    t: string;
    d: string;
}

interface Props {
    icon: 'check' | 'pause' | 'clock';
    eyebrow: string;
    title: string;
    body: string;
    note?: string;
    steps?: Step[];
}

const { icon, eyebrow, title, body, note, steps = [] } = Astro.props;
---

<section class="closing onyx">
    <div class="closing-bg" aria-hidden="true">
        <div class="closing-glow"></div>
        <div class="closing-grid"></div>
    </div>

    <div class="wrap closing-inner">
        <div class="closing-medallion" data-anim style="--d:0ms">
            <div class="closing-medallion__ring"></div>
            <span class="closing-medallion__icon">
                {icon === 'check' && (
                    <svg width="38" height="38" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="square" stroke-linejoin="miter">
                        <path d="M5 12.5 L10 17.5 L19 6.5" />
                    </svg>
                )}
                {icon === 'pause' && (
                    <svg width="34" height="34" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="square">
                        <path d="M9 5 V19 M15 5 V19" />
                    </svg>
                )}
                {icon === 'clock' && (
                    <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="square" stroke-linejoin="miter">
                        <circle cx="12" cy="12" r="8.5" />
                        <path d="M12 7.5 V12 L15.5 14" />
                    </svg>
                )}
            </span>
        </div>

        <div class="closing-eyebrow" data-anim style="--d:120ms">
            <span class="closing-dot"></span>
            <span class="eyebrow">{eyebrow}</span>
        </div>

        <h1 class="closing-title" data-anim style="--d:200ms">{title}</h1>
        <p class="closing-body" data-anim style="--d:300ms">{body}</p>

        {steps.length > 0 && (
            <div class="closing-steps" data-anim style="--d:420ms">
                {steps.map((s) => (
                    <div class="closing-step">
                        <span class="closing-step__n mono">{s.n}</span>
                        <span class="closing-step__t">{s.t}</span>
                        <span class="closing-step__d">{s.d}</span>
                    </div>
                ))}
            </div>
        )}

        <div class="closing-actions" data-anim style="--d:540ms">
            <slot name="actions" />
        </div>

        {note && <p class="closing-note" data-anim style="--d:640ms">{note}</p>}
    </div>
</section>

<style>
.closing {
    position: relative;
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    overflow: hidden;
    padding-top: clamp(96px, 12dvh, 140px);
    padding-bottom: clamp(72px, 10dvh, 110px);
    background-color: var(--color-onyx);
    color: var(--color-silver);
}
.closing-bg { position: absolute; inset: 0; z-index: 0; }
.closing-glow {
    position: absolute;
    top: -22%;
    left: 50%;
    transform: translateX(-50%);
    width: min(1000px, 120vw);
    height: 820px;
    background: radial-gradient(ellipse at center, rgba(197, 160, 89, 0.15), rgba(197, 160, 89, 0.04) 38%, transparent 64%);
    filter: blur(8px);
}
.closing-grid {
    position: absolute;
    inset: 0;
    opacity: 0.5;
    background-image:
        linear-gradient(rgba(255, 255, 255, 0.025) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255, 255, 255, 0.025) 1px, transparent 1px);
    background-size: 64px 64px;
    mask-image: radial-gradient(ellipse 80% 70% at 50% 40%, #000 30%, transparent 75%);
    -webkit-mask-image: radial-gradient(ellipse 80% 70% at 50% 40%, #000 30%, transparent 75%);
}
.closing-inner {
    position: relative;
    z-index: 2;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
}

/* medalion */
.closing-medallion {
    position: relative;
    width: 104px;
    height: 104px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 36px;
}
.closing-medallion__icon {
    display: inline-flex;
    color: var(--color-brass-bright);
    filter: drop-shadow(0 0 24px rgba(197, 160, 89, 0.35));
}
.closing-medallion__ring {
    position: absolute;
    inset: 0;
    border: 1px solid var(--color-hair-light-2);
    border-radius: 50%;
    animation: closing-spin 48s linear infinite;
}
.closing-medallion__ring::before {
    content: "";
    position: absolute;
    top: -3px;
    left: 50%;
    width: 5px;
    height: 5px;
    background: var(--color-brass-bright);
    border-radius: 50%;
    box-shadow: 0 0 10px var(--color-brass-glow);
}
@keyframes closing-spin { to { transform: rotate(360deg); } }

/* eyebrow */
.closing-eyebrow { display: inline-flex; align-items: center; gap: 10px; margin-bottom: 22px; }
.closing-eyebrow .eyebrow { color: var(--color-brass-bright); }
.closing-dot {
    width: 7px;
    height: 7px;
    background: var(--color-brass-bright);
    border-radius: 50%;
    box-shadow: 0 0 12px 1px var(--color-brass-glow);
    animation: closing-pulse 2.6s cubic-bezier(0.65, 0, 0.35, 1) infinite;
}
@keyframes closing-pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.35; } }

/* treść */
.closing-title {
    font-family: var(--font-heading);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    line-height: 1.05;
    font-size: clamp(36px, 5.4vw, 72px);
    color: var(--color-silver);
    margin: 0 0 22px;
    text-wrap: balance;
}
.closing-body {
    max-width: 600px;
    margin: 0;
    font-size: clamp(16px, 1.5vw, 19px);
    line-height: 1.65;
    color: var(--color-silver-soft);
    text-wrap: pretty;
}

/* kroki "co dalej" */
.closing-steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--color-hair-light);
    border-top: 1px solid var(--color-hair-light);
    border-bottom: 1px solid var(--color-hair-light);
    margin-top: 48px;
    max-width: 820px;
    width: 100%;
}
.closing-step {
    background: var(--color-onyx);
    padding: 26px 24px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    text-align: left;
}
.closing-step__n { font-size: 12px; letter-spacing: 0.16em; color: var(--color-brass-bright); }
.closing-step__t {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 14px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-silver);
}
.closing-step__d { font-size: 13.5px; line-height: 1.55; color: var(--color-steel); }

/* akcje + nota */
.closing-actions { display: flex; flex-wrap: wrap; gap: 16px; justify-content: center; margin-top: 44px; }
.closing-note {
    margin: 26px 0 0;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.08em;
    color: var(--color-steel);
    max-width: 520px;
    line-height: 1.7;
}

/* wejście — spokojny fade-up, bez sprężyn */
[data-anim] {
    opacity: 0;
    transform: translateY(14px);
    animation: closing-in 0.7s cubic-bezier(0.16, 1, 0.3, 1) var(--d, 0ms) forwards;
}
@keyframes closing-in { to { opacity: 1; transform: none; } }

@media (max-width: 720px) {
    .closing-steps { grid-template-columns: 1fr; }
    .closing-step { padding: 20px 22px; }
}

@media (prefers-reduced-motion: reduce) {
    [data-anim] { animation: none; opacity: 1; transform: none; }
    .closing-medallion__ring, .closing-dot { animation: none; }
}
</style>
