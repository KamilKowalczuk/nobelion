---
// AudienceMonogram: 6 unikalnych geometrycznych sygnatur dla segmentów branżowych.
// Wszystkie z tej samej rodziny: monoline, stroke 1.5, brass, viewBox 48x48,
// padding wewnętrzny 8u od krawędzi. Sugestia branży, nie literalna ikona.

interface Props {
    segment: string;
    size?: number; // w px, domyślnie 64
    class?: string;
}

const { segment, size = 64, class: className = '' } = Astro.props;

const baseSvgProps = {
    width: size,
    height: size,
    viewBox: '0 0 48 48',
    fill: 'none',
    stroke: 'var(--color-brass, #C5A059)',
    'stroke-width': '1.5',
    'stroke-linecap': 'square' as const,
    'stroke-linejoin': 'miter' as const,
    'aria-hidden': 'true' as const
};
---

{segment === 'E-COMMERCE' && (
    <svg {...baseSvgProps} class={className}>
        <!-- Pakiet/karton: prostokąt z poziomą kreską u góry, kropka w prawym górnym rogu -->
        <rect x="12" y="14" width="20" height="22" />
        <line x1="12" y1="20" x2="32" y2="20" />
        <circle cx="36" cy="14" r="2" fill="var(--color-brass, #C5A059)" stroke="none" />
    </svg>
)}

{segment === 'BIURA KSIĘGOWE I PRAWNE' && (
    <svg {...baseSvgProps} class={className}>
        <!-- Dokument z 3 liniami treści, zwieńczony trójkątem (paragraf) -->
        <rect x="12" y="14" width="20" height="22" />
        <polygon points="22,8 26,14 18,14" fill="var(--color-brass, #C5A059)" stroke="none" />
        <line x1="16" y1="22" x2="28" y2="22" />
        <line x1="16" y1="26" x2="28" y2="26" />
        <line x1="16" y1="30" x2="24" y2="30" />
    </svg>
)}

{segment === 'AGENCJE MARKETINGOWE' && (
    <svg {...baseSvgProps} class={className}>
        <!-- Promień: centralna kropka, 4 linie pod kątami (zasięg/dystrybucja) -->
        <circle cx="24" cy="24" r="2" fill="var(--color-brass, #C5A059)" stroke="none" />
        <line x1="24" y1="24" x2="10" y2="10" />
        <line x1="24" y1="24" x2="38" y2="10" />
        <line x1="24" y1="24" x2="10" y2="38" />
        <line x1="24" y1="24" x2="38" y2="38" />
    </svg>
)}

{segment === 'SPRZEDAŻ B2B' && (
    <svg {...baseSvgProps} class={className}>
        <!-- Dwa nakładające się okręgi: relacja, w przecięciu mosiężna kropka -->
        <circle cx="18" cy="24" r="10" />
        <circle cx="30" cy="24" r="10" />
        <circle cx="24" cy="24" r="2" fill="var(--color-brass, #C5A059)" stroke="none" />
    </svg>
)}

{segment === 'PRODUKCJA I HURT' && (
    <svg {...baseSvgProps} class={className}>
        <!-- Siatka 3x3 kwadratów (paleta/regały), jeden wyróżniony pełnym wypełnieniem -->
        <rect x="10" y="10" width="9" height="9" />
        <rect x="20" y="10" width="9" height="9" />
        <rect x="30" y="10" width="9" height="9" />
        <rect x="10" y="20" width="9" height="9" fill="var(--color-brass, #C5A059)" stroke="none" />
        <rect x="20" y="20" width="9" height="9" />
        <rect x="30" y="20" width="9" height="9" />
        <rect x="10" y="30" width="9" height="9" />
        <rect x="20" y="30" width="9" height="9" />
        <rect x="30" y="30" width="9" height="9" />
    </svg>
)}

{segment === 'USŁUGI LOKALNE' && (
    <svg {...baseSvgProps} class={className}>
        <!-- Okrąg z punktem w centrum + promień w prawy dół (geometryczny pinpoint) -->
        <circle cx="22" cy="22" r="12" />
        <circle cx="22" cy="22" r="2" fill="var(--color-brass, #C5A059)" stroke="none" />
        <line x1="30" y1="30" x2="40" y2="40" />
        <circle cx="40" cy="40" r="2" fill="var(--color-brass, #C5A059)" stroke="none" />
    </svg>
)}
